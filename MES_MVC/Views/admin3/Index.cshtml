@inject IMAINService _MAINService
@inject CookieHelper CookieHelper
@inject Iadmin3Service _admin3Service
@{
    //string version = GlobalHelper.InitializationDateTimeCode;
    bool IsButtonfind = false;
    bool IsButtonadd = false;
    bool IsButtonsave = false;
    bool IsButtondelete = false;
    bool IsButtoncancel = false;
    bool IsButtoninport = false;
    bool IsButtonexport = false;
    bool IsButtonprint = false;

    BaseResult BaseResult = new BaseResult();
    BaseParameter BaseParameter = new BaseParameter();
    string url = "Admin3";
    try
    {
        //truyền biến User ID thay thê cho Cookeis đẻ lấy phan quyền action cho button
        BaseParameter.USER_IDX = CookieHelper.GetCookie(GlobalHelper.USER_IDX) ?? string.Empty;
        BaseResult = await _MAINService.Main_Shown(BaseParameter);
        if (BaseResult.ListtsauthTranfer != null)
        {
            BaseResult.tsauthTranfer = BaseResult.ListtsauthTranfer.Where(o => o.SCRN_PATH == url).FirstOrDefault();
            if (BaseResult.tsauthTranfer != null)
            {
                IsButtonfind = bool.Parse(BaseResult.tsauthTranfer.IQ_AUTH_YN);
                IsButtonadd = bool.Parse(BaseResult.tsauthTranfer.RGST_AUTH_YN);
                IsButtonsave = bool.Parse(BaseResult.tsauthTranfer.MDFY_AUTH_YN);
                IsButtondelete = bool.Parse(BaseResult.tsauthTranfer.DEL_AUTH_YN);
                IsButtoncancel = bool.Parse(BaseResult.tsauthTranfer.CAN_AUTH_YN);
                IsButtoninport = bool.Parse(BaseResult.tsauthTranfer.EXCL_AUTH_YN);
                IsButtonexport = bool.Parse(BaseResult.tsauthTranfer.DNLD_AUTH_YN);
                IsButtonprint = bool.Parse(BaseResult.tsauthTranfer.PRNT_AUTH_YN);
            }
        }
    }
    catch (Exception ex)
    {
        string mes = ex.Message;
    }
    try
    {
        BaseResult = await _admin3Service.Load();
    }
    catch (Exception ex)
    {
        string mes = ex.Message;
    }
}

@{
    ViewData["Title"] = @MES_MVC.Resources.Resource.GetObject(url) + " (" + url + ")";
}

<div class="col s12 m12 l12">
    <div class="card card-default scrollspy">
        <div class="card-content">
            <div class="row">
                <div class="col s12 m12 l3">
                    <h6><b>@MES_MVC.Resources.Resource.GetObject(url) (@url)</b></h6>
                </div>
                <div class="col s12 m12 l9 right-align-md">
                    @if (IsButtonfind)
                    {
                        <button id="Buttonfind" title="@MES_MVC.Resources.Resource.Buttonfind"
                                class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                            <i class="material-icons">search</i> @MES_MVC.Resources.Resource.Buttonfind
                        </button>
                    }

                    @if (IsButtonadd)
                    {
                        <button id="Buttonadd" title="@MES_MVC.Resources.Resource.ButtonRecovery"
                                class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                            <i class="material-icons">add</i> @MES_MVC.Resources.Resource.ButtonRecovery
                        </button>
                    }

                    @* @if (IsButtonsave)
                    {
                        <button id="Buttonsave" title="@MES_MVC.Resources.Resource.Buttonsave"
                                class="btn waves-effect waves-light cyan darken-1" style="margin-right: 10px;">
                            <i class="material-icons">save</i> @MES_MVC.Resources.Resource.Buttonsave
                        </button>
                    } *@

                    @if (IsButtondelete)
                    {
                        <button id="Buttondelete" title="@MES_MVC.Resources.Resource.Buttondelete"
                                class="btn waves-effect waves-light red darken-1" style="margin-right: 10px;">
                            <i class="material-icons">delete</i> @MES_MVC.Resources.Resource.Buttondelete
                        </button>
                    }

                    @* @if (IsButtoncancel)
                    {
                        <button id="Buttoncancel" title="@MES_MVC.Resources.Resource.Buttoncancel"
                                class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                            <i class="material-icons">error</i> @MES_MVC.Resources.Resource.Buttoncancel
                        </button>
                    } *@

                    @if (IsButtoninport)
                    {
                        <button id="Buttoninport" title="@MES_MVC.Resources.Resource.Buttoninport"
                                class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                            <i class="material-icons">cloud_upload</i> @MES_MVC.Resources.Resource.Buttoninport
                        </button>
                    }

                    @if (IsButtonexport)
                    {
                        <button id="Buttonexport" title="@MES_MVC.Resources.Resource.Buttonexport"
                                class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                            <i class="material-icons">cloud_download</i> @MES_MVC.Resources.Resource.Buttonexport
                        </button>
                    }

                    @if (IsButtonprint)
                    {
                        <button id="Buttonprint" title="@MES_MVC.Resources.Resource.Buttonprint"
                                class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                            <i class="material-icons">print</i> @MES_MVC.Resources.Resource.Buttonprint
                        </button>
                    }

                    <button id="Buttonhelp" title="@MES_MVC.Resources.Resource.Buttonhelp" class="btn waves-effect waves-light green darken-1"
                            style="margin-right: 10px;">
                        <i class="material-icons">help</i>
                    </button>

                    <button id="Buttonclose" title="@MES_MVC.Resources.Resource.Buttonclose" class="btn waves-effect waves-light purple darken-1"><i class="material-icons">close</i> @MES_MVC.Resources.Resource.Buttonclose</button>
                </div>
            </div>
            <div class="row">
                <div class="row" style="margin:3px; background-color:bisque;">
                    <div class="col s12 s12 l12">
                        <div class="col s12 s3 l3">
                            <label>@MES_MVC.Resources.Resource.DbTbl_EmployID</label>
                            <input id="txt_employeeID" class="form-control" style="font-size:16px; min-height:30px;" />
                        </div>
                        <div class="col s12 s3 l3">
                            <label>@MES_MVC.Resources.Resource.DbTbl_UserName</label>
                            <input id="txt_employeeName" class="form-control" style="font-size:16px; min-height:30px;" />
                        </div> <div class="col s12 s3 l3">
                            <label>@MES_MVC.Resources.Resource.DbTbl_DepartmentName</label>
                            <input id="txt_department" class="form-control" style="font-size:16px; min-height:30px;" />
                        </div>
                        <div class="col s12 m1 l1">
                            <label>@MES_MVC.Resources.Resource.DbTbl_IsUsing</label>
                            <select id="using_selector" class="form-control browser-default" style="color: black; font-size: 14px;min-height:35px; margin-top:3px; background-color:burlywood;">
                                <option value="Y">
                                    @MES_MVC.Resources.Resource.Btn_Yes
                                </option>
                                <option value="N">
                                    @MES_MVC.Resources.Resource.Btn_No
                                </option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row" style="margin:1px; height:80vh;">
                <div class="col s12 m12 l12">
                    <table id="list_User">
                        <thead>
                            <tr>
                                <th class="text-center" style=" cursor:pointer;">@MES_MVC.Resources.Resource.DbTbl_ItemNo</th>
                                <th class="text-center" style=" cursor:pointer;">@MES_MVC.Resources.Resource.ButtonEdit</th>
                                <th class="text-center" style=" cursor:pointer;">
                                    <label style="display: flex; align-items: center; justify-content: center; gap: 2px; margin: 0;">
                                        <input id="check_all" type="checkbox" style="margin:0px;" />
                                        <span>@MES_MVC.Resources.Resource.Btn_All</span>
                                    </label>
                                </th>
                                <th class="text-center" style=" cursor:pointer;">@MES_MVC.Resources.Resource.DbTbl_User</th>
                                <th class="text-center" style=" cursor:pointer;">@MES_MVC.Resources.Resource.DbTbl_UserName</th>
                                <th class="text-center" style=" cursor:pointer;">@MES_MVC.Resources.Resource.DbTbl_DepartmentName</th>
                                <th class="text-center" style=" cursor:pointer;">@MES_MVC.Resources.Resource.DbTbl_Note</th>
                                <th class="text-center" style=" cursor:pointer;">@MES_MVC.Resources.Resource.DbTbl_PermissionGroup</th>
                                <th class="text-center" style=" cursor:pointer;">@MES_MVC.Resources.Resource.DbTbl_IsUsing</th>
                                <th class="text-center" style=" cursor:pointer;">@MES_MVC.Resources.Resource.DbTbl_CreateDate</th>
                                <th class="text-center" style=" cursor:pointer;">@MES_MVC.Resources.Resource.DbTbl_CreateBy</th>
                                <th class="text-center" style=" cursor:pointer;">@MES_MVC.Resources.Resource.DbTbl_UpdateTime</th>
                                <th class="text-center" style=" cursor:pointer;">@MES_MVC.Resources.Resource.DbTbl_UpdateBy</th>

                            </tr>
                        </thead>
                        <tbody id="list_User_view">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="editModal" class="modal" style="width:600px; height:450px;">
    <div class="modal-content">
        <label id="confirmTitle" class="header-form">@MES_MVC.Resources.Resource.MML_UserPermission: @MES_MVC.Resources.Resource.ButtonEdit </label>
        <label id="Edit_IDX" class="header-form"></label>
        <div class="row" style="margin:5px;">
            <div class="row">
                <div class="col s12 s6 l4">
                    <label>@MES_MVC.Resources.Resource.DbTbl_EmployID:</label>
                </div>
                <div class="col s12 s6 l8">
                    <input id="txt_user_ID" type="text" class="form-control" maxlength="80" style="color: black; font-size: 16px; min-height:30px;" readonly>
                </div>
            </div>
            <div class="row">
                <div class="col s12 s6 l4">
                    <label style="text-align:right;">@MES_MVC.Resources.Resource.DbTbl_UserName:</label>
                </div>
                <div class="col s12 s6 l8">
                    <input id="txt_user_NM" type="text" class="form-control" maxlength="80" style="color: black; font-size: 16px; min-height:30px;" readonly>
                </div>
            </div>
            <div class="row">
                <div class="col s12 s6 l4">
                    <label>@MES_MVC.Resources.Resource.DbTbl_DepartmentName:</label>
                </div>
                <div class="col s12 s6 l8">
                    <input id="txt_Dept" type="text" class="form-control" maxlength="80" style="color: black; font-size: 16px; min-height:30px;" readonly>
                </div>
            </div>
            <div class="row">
                <div class="col s12 s6 l4">
                    <label>@MES_MVC.Resources.Resource.DbTbl_Note:</label>
                </div>
                <div class="col s12 s6 l8">
                    <input id="txt_Note" type="text" class="form-control" maxlength="80" style="color: black; font-size: 16px; min-height:30px;" >
                </div>
            </div>
            <div class="row">
                <div class="col s12 s6 l4">
                    <label>@MES_MVC.Resources.Resource.Btn_ChangePassword:</label>
                </div>
                <div class="col s12 s6 l7">
                    <input id="txt_Password" type="text" class="form-control" maxlength="80" style="color: black; font-size: 16px; min-height:30px;">
                </div>
                <div class="col s12 s6 l1">
                    <button id="ButtonPassRandom" title="@MES_MVC.Resources.Resource.Btn_Random" style="min-width:30px;min-height:25px"
                            class="btn waves-effect waves-light green darken-1">
                        <i class="material-icons">autorenew</i>
                    </button>
                </div>
            </div>
            <div class="row">
                <div class="col s12 s6 l4">
                    <label>@MES_MVC.Resources.Resource.DbTbl_PermissionGroup:</label>
                </div>
                <div class=" col s12 m8 l8">
                    <select id="selector_PermissionGroup" class="form-control browser-default" style="color: black; font-size: 14px;min-height:32px; background-color:burlywood;">
                        @{
                            if (BaseResult.ListtsuserTranfer.Count() > 0)
                            {
                                foreach (var item in BaseResult.ListtsuserTranfer)
                                {
                                    <option value="@item.AUTH_IDX">
                                        @item.AUTH_NM
                                    </option>
                                }
                            }
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <div class="row">
            <div class="col s12 m6 l6">
                <button id="btnSave" title="@MES_MVC.Resources.Resource.Buttonsave"
                        class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                    <i class="material-icons">save</i> @MES_MVC.Resources.Resource.Buttonsave
                </button>
            </div>
            <div class="col s12 m6 l6">
                <button id="btnCancel" title="@MES_MVC.Resources.Resource.Buttoncancel"
                        class="btn waves-effect waves-light red darken-1" style="margin-right: 10px;">
                    <i class="material-icons">cancel</i> @MES_MVC.Resources.Resource.Buttoncancel
                </button>
            </div>
        </div>

    </div>
</div>

<div id="confirmModal" class="modal" style="width:600px; min-height:250px;">
    <div class="modal-content">
        <h4 id="confirmTitle">@MES_MVC.Resources.Resource.Btn_Confirm</h4>
        <p id="confirmMessage" style="font-size:20px;">Bạn có chắc chắn muốn thực hiện thao tác này?</p>
    </div>
    <div class="modal-footer">
        <div class="row">
            <div class="col s12 m6 l6">
                <button id="btn_confirmYes" title="@MES_MVC.Resources.Resource.Buttonsave"
                        class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                    <i class="material-icons">save</i> @MES_MVC.Resources.Resource.Buttonsave
                </button>
            </div>
            <div class="col s12 m6 l6">
                <button id="btn_confirmCancel" title="@MES_MVC.Resources.Resource.Buttoncancel"
                        class="btn waves-effect waves-light red darken-1" style="margin-right: 10px;">
                    <i class="material-icons">cancel</i> @MES_MVC.Resources.Resource.Buttoncancel
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    // Lấy text từ C# resource đưa vào biến JS
    const MessageText = {
        Success: '@MES_MVC.Resources.Resource.SUCCESS_Success',
        Empty: '@MES_MVC.Resources.Resource.ERROR_NoData',
        CannotDelete: '@MES_MVC.Resources.Resource.ERROR_CannotDelete',
        NotSelectOnGrid:'@MES_MVC.Resources.Resource.WARN_NotSelectOnGrid',
        DeleteData: '@MES_MVC.Resources.Resource.CONFIRM_Delete',
        RecoveryData: '@MES_MVC.Resources.Resource.MSG_RecoveryData',
    };

    const HeaderText = {
        No: '@MES_MVC.Resources.Resource.DbTbl_ItemNo',
        ID: '@MES_MVC.Resources.Resource.DbTbl_ID',
        GroupCode: '@MES_MVC.Resources.Resource.DbTbl_GroupCode',
        GroupName: '@MES_MVC.Resources.Resource.DbTbl_GroupName',
        Edit: '@MES_MVC.Resources.Resource.MML_UserPermission',
        Create: '@MES_MVC.Resources.Resource.DbTbl_PermissionGroup: @MES_MVC.Resources.Resource.Buttonadd',
    };

</script>

<script src="~/Scripts/admin3.js?v=@GlobalHelper.GetVersionScrip("admin3.js")"></script>

