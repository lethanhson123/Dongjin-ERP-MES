                </div>
            </div>
            <div class="col s12 m12 l2">
                <div>
                    <label>.</label>
                    <input id="EXCELTextBox15" type="text" class="form-control" readonly>
                </div>
            </div>
            <div class="col s12 m12 l1">
                <div>
                    <label>Count : </label>
                    <input id="EXCELLabel3" type="text" class="form-control" readonly>
                </div>
            </div>
            <div class="col s12 m12 l1">
                <div>
                    <br />
                    <button id="EXCELButtondelete" class="btn waves-effect waves-light red darken-1" style="width:100%;">Delete</button>
                </div>
            </div>
            <div class="col s12 m12 l1">
                <div>
                    <br />
                    <button id="EXCELButtonsave" class="btn waves-effect waves-light cyan darken-1" style="width:100%;">Save</button>
