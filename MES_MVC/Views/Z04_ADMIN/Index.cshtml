                    <label>Download <a id="ExcelTemplateLink" href="#" title="Excel Template">Excel Template</a> (if you don't have it)</label>
                    <input id="FileToUpload" type="file" class="form-control" accept=".xls,.xlsx" style="display:none;">
                </div>
            </div>
        </div>
        <div class="row card-panel light-blue lighten-4">
            <div class="col s12 m12 l3">
                <div>
                    <label>Option : </label>
                    <br />
                    <label>
                        <input id="EXCELRadioButton1" name="Z04_ADMIN_EXCEL" type="radio" />
