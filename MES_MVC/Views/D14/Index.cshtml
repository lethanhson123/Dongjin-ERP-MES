<script>
    const sortState = {};
    function sortTable(tableId, columnIndex) {
        const table = document.getElementById(tableId);
        const tbody = table.tBodies[0];
        const rows = Array.from(tbody.rows);
        // Key duy nhất cho từng bảng và cột
        const key = tableId + "_" + columnIndex;
        const currentDirection = sortState[key] || 'asc';

        rows.sort((a, b) => {
            let cellA = a.cells[columnIndex].innerText.trim().toLowerCase();
            let cellB = b.cells[columnIndex].innerText.trim().toLowerCase();
            // So sánh số nếu có thể
            const isNumeric = !isNaN(cellA) && !isNaN(cellB);
            if (isNumeric) {
                cellA = parseFloat(cellA);
                cellB = parseFloat(cellB);
            }
            if (cellA < cellB) return currentDirection === 'asc' ? -1 : 1;
            if (cellA > cellB) return currentDirection === 'asc' ? 1 : -1;
            return 0;
        });
        // Gắn lại thứ tự
        while (tbody.firstChild) {
            tbody.removeChild(tbody.firstChild);
        }
        rows.forEach(row => tbody.appendChild(row));
        // Lưu trạng thái lần sau đảo chiều
        sortState[key] = currentDirection === 'asc' ? 'desc' : 'asc';
    }

     // Lấy text từ C# resource đưa vào biến JS
    const localizedText = {
        TotalDelete: '@MES_MVC.Resources.Resource.DbTbl_TotalQuantity',
        search: '@MES_MVC.Resources.Resource.Btn_Search',
        reset: '@MES_MVC.Resources.Resource.ButtonREST',
        WrongCode: '@MES_MVC.Resources.Resource.ERROR_NotExisted',
        WrongProduct: '@MES_MVC.Resources.Resource.ERROR_WrongProductCode',
        Scanned: '@MES_MVC.Resources.Resource.WARN_ScanExisted',
        Success: '@MES_MVC.Resources.Resource.SUCCESS_Success',
        Empty: '@MES_MVC.Resources.Resource.ERROR_NoData',
        FullBox: '@MES_MVC.Resources.Resource.ERROR_FullBox',
        CannotDelete: '@MES_MVC.Resources.Resource.ERROR_CannotDelete',
        Remark: '@MES_MVC.Resources.Resource.DbTbl_Remark',
        confirmScanMore: '@MES_MVC.Resources.Resource.MSG_AddPackingItem',
        TurnofUnikey:'@MES_MVC.Resources.Resource.MSG_UnikeyTurnOff'
    };

    document.addEventListener('DOMContentLoaded', function () {
        const tabLinks = document.querySelectorAll('.tabs a');
        const btn = document.getElementById('Buttonfind');
        tabLinks.forEach(link => {
            link.addEventListener('click', function () {
                const href = this.getAttribute('href'); // VD: #Tag001

                if (href === "#Tag001") {
                    btn.innerHTML = `<i class="material-icons">refresh</i>${localizedText.reset}`;

                } else {
                   btn.innerHTML = `<i class="material-icons">search</i>${localizedText.search}`;
                }
            });
        });
        var elems = document.querySelectorAll('.modal');
        M.Modal.init(elems, {
            dismissible: false //Không cho phép click ngoài để đóng
        });
    });

     const input = document.getElementById("tab1_QRCodeScan");
     input.addEventListener("input", function () {
        const original = this.value;
        const asciiOnly = original.replace(/[^\x00-\x7F]/g, '');

        if (original !== asciiOnly) {
            this.value = asciiOnly;
            // Cảnh báo nếu có ký tự Unicode bị loại bỏ
            showCustomAlert(localizedText.TurnofUnikey);
        }
    });

     let tabChucNang = null;

    function openOrFocusTab() {
      const url = 'F02'; // thay bằng URL của bạn

      // Nếu tab chưa mở hoặc đã bị đóng
      if (!tabChucNang || tabChucNang.closed) {
        tabChucNang = window.open(url, '_blank');
      } else {
        // Nếu tab đã mở, chuyển đến tab đó
        tabChucNang.focus();
      }
    }

</script>

