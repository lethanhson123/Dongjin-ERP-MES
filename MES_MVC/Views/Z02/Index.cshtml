                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
            <!-- TabPage2: Search Request -->
            <!-- TabPage3: User Management -->
            <div class="row" id="TabPage3">
                <div class="col s12 m12 l12 card-panel yellow lighten-4">
                    <div class="row">
                        <div class="col s12 m12 l3">
                            <div>
                                <label>Request ID</label>
                                <input id="Label7" type="text" class="form-control" readonly>
                            </div>
                        </div>
                        <div class="col s12 m12 l3">
                            <div>
                                <label>User ID</label>
                                <input id="TextBox5" type="text" class="form-control">
                            </div>
                        </div>
                        <div class="col s12 m12 l3">
                            <div>
                                <label>User Name</label>
                                <input id="TextBox6" type="text" class="form-control">
                            </div>
                        </div>
                        <div class="col s12 m12 l3">
                            <div>
                                <label>Department</label>
                                <input id="TextBox8" type="text" class="form-control">
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col s12 m12 l3">
                            <div>
                                <label>Authority</label>
                                <input id="TextBox7" type="text" class="form-control">
                            </div>
                        </div>
                        <div class="col s12 m12 l3">
                            <div>
                                <label>Authority Level</label>
                                <select id="ComboBox6" class="browser-default form-select">
                                    <option value="">Select Item...</option>
                                </select>
                            </div>
                        </div>
                        <div class="col s12 m12 l3">
                            <div>
                                <label>Filter</label>
                                <div class="col s12 m12 l12">
                                    <label><input id="RadioButton1" name="filter" type="radio" checked><span>Open List</span></label>
                                    <label><input id="RadioButton2" name="filter" type="radio"><span>All List</span></label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="KhungOverflow50">
                    <table class="responsive-table" id="DataGridView3">
                        <thead class="sticky-header">
                            <tr onclick="DataGridView3Sort()">
                                <th>Apply</th>
                                <th>Complete</th>
                                <th>DATE</th>
                                <th>NOTE</th>
                                <th>NEW ID</th>
                                <th>NAME</th>
                                <th>Department</th>
                                <th>Use_LEVEL</th>
                                <th>IDX</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="~/Scripts/Z02.js?v=@version"></script>