                                <select id="ComboBox3" class="browser-default form-select">
                                    <option value="">Select Item...</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="KhungOverflow50">
                    <table class="responsive-table" id="DataGridView1">
                        <thead class="sticky-header">
                            <tr onclick="DataGridView1Sort()">
                                <th>Requester</th>
                                <th>DATE</th>
