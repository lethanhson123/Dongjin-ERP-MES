                            <th>PDP_MEMO</th>
                            <th>CREATE_DTM</th>
                            <th>CREATE_USER</th>
                            <th>NAME</th>
                            <th>PDP_PART</th>
                            <th>STOCK</th>
                            <th>PDPUSCH_IDX</th>
                            <th>PDP_COST</th>
                            <th>SUM_COST</th>
                            <th>PDP_VAT</th>
                            <th>PDP_ECTCOST</th>
                            <th>PDP_TOTCOST</th>
                            <th>PDP_BE_COST</th>
                            <th>PDP_CMPY</th>
                            <th>COMP_NM</th>
                        </tr>
                    </thead>
                    <tbody id="DataGridView1">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<script src="~/Scripts/V03_3.js?v=@version"></script>

