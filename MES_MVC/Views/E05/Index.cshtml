@inject IMAINService _MAINService
@inject CookieHelper CookieHelper
@inject IE05Service _E05Service
@{
    string version = GlobalHelper.InitializationDateTimeCode;
    bool IsButtonfind = false;
    bool IsButtonadd = false;
    bool IsButtonsave = false;
    bool IsButtondelete = false;
    bool IsButtoncancel = false;
    bool IsButtoninport = false;
    bool IsButtonexport = false;
    bool IsButtonprint = false;

    BaseResult BaseResult = new BaseResult();
    BaseParameter BaseParameter = new BaseParameter();
    string url = "E05";
    try
    {
        //truyền biến User ID thay thê cho Cookeis đẻ lấy phan quyền action cho button
        BaseParameter.USER_IDX = CookieHelper.GetCookie(GlobalHelper.USER_IDX) ?? string.Empty;
        BaseResult = await _MAINService.Main_Shown(BaseParameter);
        if (BaseResult.ListtsauthTranfer != null)
        {
            BaseResult.tsauthTranfer = BaseResult.ListtsauthTranfer.Where(o => o.SCRN_PATH == url).FirstOrDefault();
            if (BaseResult.tsauthTranfer != null)
            {
                IsButtonfind = bool.Parse(BaseResult.tsauthTranfer.IQ_AUTH_YN);
                IsButtonadd = bool.Parse(BaseResult.tsauthTranfer.RGST_AUTH_YN);
                IsButtonsave = bool.Parse(BaseResult.tsauthTranfer.MDFY_AUTH_YN);
                IsButtondelete = bool.Parse(BaseResult.tsauthTranfer.DEL_AUTH_YN);
                IsButtoncancel = bool.Parse(BaseResult.tsauthTranfer.CAN_AUTH_YN);
                IsButtoninport = bool.Parse(BaseResult.tsauthTranfer.EXCL_AUTH_YN);
                IsButtonexport = bool.Parse(BaseResult.tsauthTranfer.DNLD_AUTH_YN);
                IsButtonprint = bool.Parse(BaseResult.tsauthTranfer.PRNT_AUTH_YN);
            }
        }
    }
    catch (Exception ex)
    {
        string mes = ex.Message;
    }
    try
    {
        BaseResult = await _E05Service.Load();
    }
    catch (Exception ex)
    {
        string mes = ex.Message;
    }
}

@{
    ViewData["Title"] = @MES_MVC.Resources.Resource.GetObject(url) + " (" + url + ")";
}

<div class="col s12 m12 l12">
    <div class="card card card-default scrollspy">
        <div class="card-content">
            <div class="row">
                <div class="col s12 m12 l4">
                    <h6><b>@MES_MVC.Resources.Resource.GetObject(url) (@url)</b></h6>
                </div>
                <div class="col s12 m12 l8 right-align-md">
                    <button @(IsButtonfind ? "" : "Disabled") id="Buttonfind" title="@MES_MVC.Resources.Resource.Buttonfind" class="btn waves-effect waves-light green darken-1"
                            style="margin-right: 10px;">
                        <i class="material-icons">search</i> @MES_MVC.Resources.Resource.Buttonfind
                    </button>

                    <button @(IsButtonadd ? "" : "Disabled") id="Buttonadd" title="@MES_MVC.Resources.Resource.Buttonadd" class="btn waves-effect waves-light green darken-1"
                            style="margin-right: 10px;">
                        <i class="material-icons">add</i> @MES_MVC.Resources.Resource.Buttonadd
                    </button>

                    <button @(IsButtonsave ? "" : "Disabled") id="Buttonsave" title="@MES_MVC.Resources.Resource.Buttonsave" class="btn waves-effect waves-light cyan darken-1"
                            style="margin-right: 10px;">
                        <i class="material-icons">save</i> @MES_MVC.Resources.Resource.Buttonsave
                    </button>

                    <button @(IsButtondelete ? "" : "Disabled") id="Buttondelete" title="@MES_MVC.Resources.Resource.Buttondelete" class="btn waves-effect waves-light red darken-1"
                            style="margin-right: 10px;">
                        <i class="material-icons">delete</i> @MES_MVC.Resources.Resource.Buttondelete
                    </button>

                    <button @(IsButtoncancel ? "" : "Disabled") id="Buttoncancel" title="@MES_MVC.Resources.Resource.Buttoncancel" class="btn waves-effect waves-light green darken-1"
                            style="margin-right: 10px;">
                        <i class="material-icons">error</i> @MES_MVC.Resources.Resource.Buttoncancel
                    </button>

                    <button @(IsButtoninport ? "" : "Disabled") id="Buttoninport" title="@MES_MVC.Resources.Resource.Buttoninport" class="btn waves-effect waves-light green darken-1"
                            style="margin-right: 10px;">
                        <i class="material-icons">cloud_upload</i> @MES_MVC.Resources.Resource.Buttoninport
                    </button>

                    <button @(IsButtonexport ? "" : "Disabled") id="Buttonexport" title="@MES_MVC.Resources.Resource.Buttonexport" class="btn waves-effect waves-light green darken-1"
                            style="margin-right: 10px;">
                        <i class="material-icons">cloud_download</i> @MES_MVC.Resources.Resource.Buttonexport
                    </button>

                    <button @(IsButtonprint ? "" : "Disabled") id="Buttonprint" title="@MES_MVC.Resources.Resource.Buttonprint" class="btn waves-effect waves-light green darken-1"
                            style="margin-right: 10px;">
                        <i class="material-icons">print</i> @MES_MVC.Resources.Resource.Buttonprint
                    </button>

                    <button id="Buttonhelp" title="@MES_MVC.Resources.Resource.Buttonhelp" class="btn waves-effect waves-light green darken-1"
                            style="margin-right: 10px;">
                        <i class="material-icons">help</i>
                    </button>

                    <button id="Buttonclose" title="@MES_MVC.Resources.Resource.Buttonclose" class="btn waves-effect waves-light purple darken-1">
                        <i class="material-icons">close</i> @MES_MVC.Resources.Resource.Buttonclose
                    </button>
                </div>
            </div>

            <!-- Tab Navigation -->
            <div class="row">
                <div class="col s12 m12 l6">
                    <ul class="tabs">
                        <li class="tab col s4 p-0">
                            <a id="ATagTabPage1" class="active p-0" href="#TabPage1">Material Order</a>
                        </li>
                        <li class="tab col s4 p-0">
                            <a id="ATagTabPage2" class="p-0" href="#TabPage2">Material Approve</a>
                        </li>
                        <li class="tab col s4 p-0">
                            <a id="ATagTabPage3" class="p-0" href="#TabPage3">Material List</a>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Tab 1: Material Order Content -->
            <div class="row" id="TabPage1">
                <!-- Filter Panel -->
                <div class="col s12 m12 l12 card-panel light-blue lighten-4">
                    <div class="col s12 m12 l3">
                        <div>
                            <label>Factory : </label>
                            <select id="CB_FCTRY1" class="browser-default form-select">
                                <option value="Factory 1">Factory 1</option>
                            </select>
                        </div>
                    </div>
                    <div class="col s12 m12 l3">
                        <div>
                            <label>DATE :</label>
                            <input id="DateTimePicker2" type="date" class="form-control" value="2025-06-01">
                        </div>
                    </div>
                    <div class="col s12 m12 l6">
                        <!-- Empty space for alignment -->
                    </div>
                </div>

                <!-- Radio Button Options -->
                <div class="col s12 m12 l12">
                    <div class="col s12 m12 l6">
                        <label>
                            <input id="RadioButton2" name="selectOption" type="radio" />
                            <span>Select All</span>
                        </label>
                        <label style="margin-left: 20px;">
                            <input id="RadioButton1" name="selectOption" type="radio" />
                            <span>Select Cancel</span>
                        </label>
                    </div>
                </div>

                <!-- Main Content Area -->
                <div class="row">
                    <!-- Left Panel: DATE/STAGE Table -->
                    <div class="col s12 m12 l3">
                        <div class="KhungOverflow60">
                            <table class="responsive-table striped" id="DataGridView2">
                                <thead class="sticky-header">
                                    <tr>
                                        <th>DATE</th>
                                        <th>STAGE</th>
                                    </tr>
                                </thead>
                                <tbody id="DataGridView2Body">
                                    <!-- Data will be populated by JavaScript -->
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Right Panel: Main Data Table -->
                    <div class="col s12 m12 l9">
                        <div class="KhungOverflow60">
                            <table class="responsive-table striped" id="DataGridView3">
                                <thead class="sticky-header">
                                    <tr>
                                        <th></th>
                                        <th>ORDER_NO</th>
                                        <th>STAGE</th>
                                        <th>DATE</th>
                                        <th>WH ORDER</th>
                                        <th>WHY(YN)</th>
                                        <th>DJG_CODE</th>
                                        <th>PART_NO</th>
                                        <th>PART_NAME</th>
                                        <th>FAMILY</th>
                                        <th>SNP</th>
                                        <th>QTY</th>
                                        <th>STOCK</th>
                                    </tr>
                                </thead>
                                <tbody id="DataGridView3Body">
                                    <!-- Data will be populated by JavaScript -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab 2: Material Approve Content -->
            <div class="row" id="TabPage2" style="display: none;">
                <!-- Filter Panel - Green Background -->
                <div class="col s12 m12 l12 card-panel green lighten-4">
                    <div class="col s12 m12 l3">
                        <div>
                            <label>Factory : </label>
                            <select id="CB_FCTRY3" class="browser-default form-select">
                                <option value="Factory 1">Factory 1</option>
                            </select>
                        </div>
                    </div>
                    <div class="col s12 m12 l3">
                        <div>
                            <label>DATE :</label>
                            <input id="T2_S2" type="date" class="form-control" value="2025-06-19">
                        </div>
                    </div>
                    <div class="col s12 m12 l3">
                        <div>
                            <label>검색 Tìm :</label>
                            <input id="T2_S3" type="text" class="form-control" placeholder="">
                        </div>
                    </div>
                   
                </div>

                <!-- Radio Button Options -->
                <div class="col s12 m12 l12">
                    <div class="col s12 m12 l6">
                        <label>
                            <input id="rbchk1" name="selectOption_TAB2" type="radio" />
                            <span>Select All</span>
                        </label>
                        <label style="margin-left: 20px;">
                            <input id="rbchk2" name="selectOption_TAB2" type="radio" />
                            <span>Select Cancel</span>
                        </label>
                    </div>
                </div>

                <!-- Single Data Table -->
                <div class="col s12 m12 l12">
                    <div class="KhungOverflow60">
                        <table class="responsive-table striped" id="DataGridView4">
                            <thead class="sticky-header">
                                <tr>
                                    <th></th>
                                    <th>STAGE</th>
                                    <th>Complete</th>
                                    <th>DATE</th>
                                    <th>DJG_CODE</th>
                                    <th>PART_NO</th>
                                    <th>PART_NAME</th>
                                    <th>FAMILY</th>
                                    <th>PART_SNP</th>
                                    <th>QTY</th>
                                </tr>
                            </thead>
                            <tbody id="DataGridView4Body">
                                <!-- Data will be populated by JavaScript -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Tab 3: Material List Content -->
            <div class="row" id="TabPage3" style="display: none;">
                <!-- Filter Panel - Cyan Background -->
                <div class="col s12 m12 l12 card-panel cyan lighten-4">
                    <div class="col s12 m12 l2">
                        <div>
                            <label>Factory : </label>
                            <select id="CB_FCTRY2" class="browser-default form-select">
                                <option value="Factory 1">Factory 1</option>
                            </select>
                        </div>
                    </div>
                    <div class="col s12 m12 l2">
                        <div>
                            <label>DATE :</label>
                            <input id="T3_S2" type="date" class="form-control" value="2025-06-19">
                        </div>
                    </div>
                    <div class="col s12 m12 l2">
                        <div>
                            <label>PART NO(검색 Tìm) :</label>
                            <input id="T3_S3" type="text" class="form-control" placeholder="">
                        </div>
                    </div>
                    <div class="col s12 m12 l2">
                        <div>
                            <label>NAME(검색 Tìm) :</label>
                            <input id="T2_S4" type="text" class="form-control" placeholder="">
                        </div>
                    </div>
                    <div class="col s12 m12 l2">
                        <div>
                            <label>Complete :</label>
                            <select id="T2_S6" class="browser-default form-select">
                                <option value="ALL">ALL</option>
                                <option value="Y">Y</option>
                                <option value="N">N</option>
                            </select>
                        </div>
                    </div>
                    <div class="col s12 m12 l2">
                        <!-- Empty space -->
                    </div>
                </div>

                <!-- Single Data Table -->
                <div class="col s12 m12 l12">
                    <div class="KhungOverflow60">
                        <table class="responsive-table striped" id="T2_DGV1">
                            <thead class="sticky-header">
                                <tr>
                                    <th>Order_Chk</th>
                                    <th>Complete</th>
                                    <th>STAGE</th>
                                    <th>FAMILY</th>
                                    <th>PART_NO</th>
                                    <th>PART_NAME</th>
                                    <th>QTY</th>
                                    <th>Date of Request</th>
                                    <th>Order</th>
                                </tr>
                            </thead>
                            <tbody id="T2_DGV1Body">
                                <!-- Data will be populated by JavaScript -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/Scripts/E05.js?v=@version"></script>