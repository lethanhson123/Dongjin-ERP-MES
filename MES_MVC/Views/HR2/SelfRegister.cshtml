@{
    Layout = null; // Không dùng layout chính
    ViewData["Title"] = "Đăng Ký Thông Tin Nhân Viên";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <!-- Materialize CSS -->
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link rel="stylesheet" href="~/css/materialize.min.css">

    <style>
        body {
            background-color: #f5f5f5;
        }

        .registration-container {
            margin-top: 50px;
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
        }

        .card-title {
            color: #1976d2;
            font-weight: bold;
        }

        #BackGround {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.5);
            z-index: 9999;
        }

        .loader {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }
    </style>
</head>
<body>
    <!-- Loader -->
    <div id="BackGround">
        <div class="preloader-wrapper big active loader">
            <div class="spinner-layer spinner-blue-only">
                <div class="circle-clipper left">
                    <div class="circle"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="registration-container">
        <div class="card">
            <div class="card-content">
                <h4 class="card-title center">ĐĂNG KÝ THÔNG TIN NHÂN VIÊN</h4>
                <p class="center">Vui lòng điền đầy đủ thông tin bên dưới</p>

                <form id="SelfRegistrationForm">
                    <!-- Thông tin cá nhân -->
                    <div class="row">
                        <div class="col s12">
                            <h6><b>Thông tin cá nhân</b></h6>
                        </div>

                        <div class="input-field col s12 m6">
                            <input id="TextBox_Name" type="text" class="validate" required>
                            <label for="TextBox_Name">Họ và tên <span class="red-text">*</span></label>
                        </div>

                        <div class="input-field col s12 m6">
                            <select id="ComboBox_Gender" required>
                                <option value="" disabled selected>Chọn giới tính</option>
                                <option value="Nam">Nam</option>
                                <option value="Nữ">Nữ</option>
                            </select>
                            <label>Giới tính <span class="red-text">*</span></label>
                        </div>

                        <div class="input-field col s12 m6">
                            <input id="DatePicker_DOB" type="date" class="validate" required>
                            <label for="DatePicker_DOB">Ngày sinh <span class="red-text">*</span></label>
                        </div>

                        <div class="input-field col s12 m6">
                            <select id="ComboBox_MaritalStatus">
                                <option value="" selected>Chọn tình trạng</option>
                                <option value="Độc thân">Độc thân</option>
                                <option value="Đã kết hôn">Đã kết hôn</option>
                                <option value="Ly hôn">Ly hôn</option>
                            </select>
                            <label>Tình trạng hôn nhân</label>
                        </div>

                        <div class="input-field col s12 m6">
                            <input id="TextBox_Dependents" type="number" min="0">
                            <label for="TextBox_Dependents">Số người phụ thuộc</label>
                        </div>
                    </div>

                    <!-- Thông tin CCCD -->
                    <div class="row">
                        <div class="col s12">
                            <h6><b>Thông tin CCCD/CMND</b></h6>
                        </div>

                        <div class="input-field col s12 m4">
                            <input id="TextBox_CitizenID" type="text" class="validate" required maxlength="12">
                            <label for="TextBox_CitizenID">Số CCCD <span class="red-text">*</span></label>
                        </div>

                        <div class="input-field col s12 m4">
                            <input id="DatePicker_IDIssueDate" type="date" class="validate" required>
                            <label for="DatePicker_IDIssueDate">Ngày cấp <span class="red-text">*</span></label>
                        </div>

                        <div class="input-field col s12 m4">
                            <input id="TextBox_IDIssuePlace" type="text" class="validate" required>
                            <label for="TextBox_IDIssuePlace">Nơi cấp <span class="red-text">*</span></label>
                        </div>
                    </div>

                    <!-- Thông tin liên lạc -->
                    <div class="row">
                        <div class="col s12">
                            <h6><b>Thông tin liên lạc</b></h6>
                        </div>

                        <div class="input-field col s12">
                            <textarea id="TextBox_PermAddress" class="materialize-textarea validate" required></textarea>
                            <label for="TextBox_PermAddress">Địa chỉ thường trú <span class="red-text">*</span></label>
                        </div>

                        <div class="input-field col s12">
                            <textarea id="TextBox_CurrAddress" class="materialize-textarea validate" required></textarea>
                            <label for="TextBox_CurrAddress">Địa chỉ hiện tại <span class="red-text">*</span></label>
                        </div>

                        <div class="input-field col s12 m6">
                            <input id="TextBox_Phone" type="tel" class="validate" required maxlength="11">
                            <label for="TextBox_Phone">Số điện thoại <span class="red-text">*</span></label>
                        </div>

                        <div class="input-field col s12 m6">
                            <input id="TextBox_Email" type="email" class="validate">
                            <label for="TextBox_Email">Email</label>
                        </div>
                    </div>

                    <!-- Hidden token -->
                    <input type="hidden" id="RegistrationToken" value="@ViewBag.Token" />

                    <!-- Submit button -->
                    <div class="row">
                        <div class="col s12 center">
                            <button type="submit" class="btn waves-effect waves-light blue">
                                <i class="material-icons left">save</i>
                                Hoàn Thành Đăng Ký
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/js/jquery-3.6.0.min.js"></script>
    <script src="~/js/materialize.min.js"></script>
    <script src="~/Scripts/SelfRegister.js"></script>
</body>
</html>