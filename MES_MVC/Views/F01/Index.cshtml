                            </div>
                            <div class="col s12 m12 l4">
                                <label class="input100" style="color:black; font-size:20px">@MES_MVC.Resources.Resource.Btn_Search</label>
                                <input type="text" id="tab2_Search" class="form-control" maxlength="80"
                                       style="color: black; font-size: 16px; min-height:30px;" autocomplete="off">
                            </div>
                            <div class="col s12 m12 l1">
