                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col s12 m4 l4">
                            <div class="picture-container">
                                <img id="pictureUpload" src="" alt="@MES_MVC.Resources.Resource.DbTbl_NoPicture" style="min-width:120px; min-height:120px; max-height:220px; " />
                                <button type="button" class="upload-btn">Upload</button>
                                <input type="file" id="fileInput" accept="image/*" style="display:none;" />
                            </div>
                        </div>
                    </div>
                    <div class="row" style="margin:3px;">
                        <div class="col s12">
                            <table class="display wrap" id="Table1" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>@MES_MVC.Resources.Resource.DbTbl_Supplier</th>
                                        <th>@MES_MVC.Resources.Resource.DbTbl_Invoice</th>
                                        <th>@MES_MVC.Resources.Resource.DbTbl_ScanQRCode</th>
                                        <th>@MES_MVC.Resources.Resource.DbTbl_PartNo</th>
                                        <th>Sample</th>
                                        <th>Total Invoice</th>
                                        <th>@MES_MVC.Resources.Resource.DbTbl_NGQty</th>
                                        <th>@MES_MVC.Resources.Resource.DbTbl_Unit</th>
                                        <th>@MES_MVC.Resources.Resource.DbTbl_Percentage</th>
                                        <th>@MES_MVC.Resources.Resource.DbTbl_DateIn</th>
                                        <th>@MES_MVC.Resources.Resource.DbTbl_DateCheck</th>
                                        <th>@MES_MVC.Resources.Resource.DbTbl_Week</th>
                                        <th>@MES_MVC.Resources.Resource.DbTbl_Month</th>
                                        <th>@MES_MVC.Resources.Resource.DbTbl_Content</th>
                                        <th>@MES_MVC.Resources.Resource.DbTbl_Picture</th>
                                        <th>@MES_MVC.Resources.Resource.DbTbl_Status</th>
                                        <th>@MES_MVC.Resources.Resource.DbTbl_Note</th>
                                        <th>@MES_MVC.Resources.Resource.DbTbl_CreateBy</th>
                                        <th>@MES_MVC.Resources.Resource.DbTbl_CreateDate</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- ✅ THAY TABLE2 TRONG TAG002 -->
                <div id="Tag002" class="col s12">
                    <div class="col s12 m6 l12 card-panel light-blue lighten-4">
                        <div class="row p-0 m-0">
                            <div class="col s12 m6 l1">
                                <label style="font-size:20px;">@MES_MVC.Resources.Resource.DbTbl_FromDate</label>
                                <input id="tab2_fromDate" type="date" class="form-control" style="color: black; min-height:30px;"
