                            </div>
                        </div>
                        <div class="col s12 m12 l2">
                            <div>
                                <label>Group Code :</label>
                                <input id="TextBox5" type="text" class="form-control">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="KhungOverflow60">
                    <table class="responsive-table" id="DataGridView3Table">
                        <thead class="sticky-header">
                            <tr onclick="DataGridView3Sort()">
                                <th></th>
                                <th>DATE</th>
                                <th>BARCODE_ID</th>
