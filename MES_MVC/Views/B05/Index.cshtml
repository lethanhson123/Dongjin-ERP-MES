                        <!-- Column 3: Product, W×L×H, Total Area -->
                        <div class="col s12 m12 l2">
                            <div>
                                <label>Product :</label>
                                <input id="T4_T03" type="text" class="form-control">
                            </div>
                            <div style="margin-top: 10px;">
                                <label>W × L × H (Cm) :</label>
                                <input id="T4_T07" type="text" class="form-control">
                            </div>
                            <div style="margin-top: 10px;">
                                <label>Total Area(m²) :</label>
                                <input id="T4_T13" type="number" class="form-control" step="0.01">
                            </div>
                        </div>

                        <!-- Column 4: Family, MRP(SAFETY), Weight -->
                        <div class="col s12 m12 l2">
