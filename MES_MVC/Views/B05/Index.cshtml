                        </div>
                        <div class="col s12 m12 l2">
                            <div>
                                <label>PART NAME :</label>
                                <input id="suchTB2" type="text" class="form-control">
                            </div>
                        </div>
                        <div class="col s12 m12 l2">
                            <div>
