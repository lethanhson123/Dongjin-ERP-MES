                    </div>
                </div>

                <!-- Details Section - Green background -->
                <div class="col s12 m12 l12 card-panel light-green lighten-4">
                    <div class="row">
                        <!-- Column 1: PART NO, Model, Unit Area -->
                        <div class="col s12 m12 l2">
                            <div>
                                <label>PART NO :</label>
                                <input id="T4_T01" type="text" class="form-control">
                            </div>
                            <div style="margin-top: 10px;">
                                <label>Model :</label>
                                <input id="T4_T05" type="text" class="form-control">
                            </div>
                            <div style="margin-top: 10px;">
                                <label>Unit Area :</label>
                                <input id="T4_T11" type="number" class="form-control" step="0.01">
                            </div>
                        </div>

                        <!-- Column 2: PART NAME, SNP, BOX COUNT -->
                        <div class="col s12 m12 l2">
                            <div>
                                <label>PART NAME :</label>
                                <input id="T4_T02" type="text" class="form-control">
                            </div>
                            <div style="margin-top: 10px;">
                                <label>SNP :</label>
                                <input id="T4_T06" type="text" class="form-control">
                            </div>
                            <div style="margin-top: 10px;">
                                <label>BOX COUNT :</label>
                                <input id="T4_T12" type="number" class="form-control">
                            </div>
