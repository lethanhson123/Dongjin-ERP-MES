                <!-- Data Table -->
                <div class="KhungOverflow60">
                    <table class="responsive-table" id="DataGridView4Table">
                        <thead class="sticky-header">
                            <tr onclick="DataGridView4Sort()">
                                <th>CODE</th>
                                <th>PART_NO</th>
