                        </thead>
                        <tbody id="DataGridView2">
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="row" id="Tag003" style="display: none;">
                <div class="col s12 m12 l12 card-panel purple lighten-4">
                    <div class="row">
                        <div class="col s12 m12 l2">
                            <div>
                                <label>PART NO :</label>
