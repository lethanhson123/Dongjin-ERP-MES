                            </div>
                            <div style="margin-top: 10px;">
                                <label>MRP(SAFETY) :</label>
                                <input id="T4_T10" type="text" class="form-control">
                            </div>
                            <div style="margin-top: 10px;">
                                <label>Weight (G) :</label>
                                <input id="txt_DVT" type="number" class="form-control" step="0.01">
