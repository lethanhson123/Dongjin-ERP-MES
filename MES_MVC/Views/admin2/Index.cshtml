@inject IMAINService _MAINService
@inject CookieHelper CookieHelper
@inject Iadmin2Service _admin2Service
@{
    //string version = GlobalHelper.InitializationDateTimeCode;
    bool IsButtonfind = false;
    bool IsButtonadd = false;
    bool IsButtonsave = false;
    bool IsButtondelete = false;
    bool IsButtoncancel = false;
    bool IsButtoninport = false;
    bool IsButtonexport = false;
    bool IsButtonprint = false;

    BaseResult BaseResult = new BaseResult();
    BaseParameter BaseParameter = new BaseParameter();
    string url = "Admin2";
    try
    {
        //truyền biến User ID thay thê cho Cookeis đẻ lấy phan quyền action cho button
        BaseParameter.USER_IDX = CookieHelper.GetCookie(GlobalHelper.USER_IDX) ?? string.Empty;
        BaseResult = await _MAINService.Main_Shown(BaseParameter);
        if (BaseResult.ListtsauthTranfer != null)
        {
            BaseResult.tsauthTranfer = BaseResult.ListtsauthTranfer.Where(o => o.SCRN_PATH == url).FirstOrDefault();
            if (BaseResult.tsauthTranfer != null)
            {
                IsButtonfind = bool.Parse(BaseResult.tsauthTranfer.IQ_AUTH_YN);
                IsButtonadd = bool.Parse(BaseResult.tsauthTranfer.RGST_AUTH_YN);
                IsButtonsave = bool.Parse(BaseResult.tsauthTranfer.MDFY_AUTH_YN);
                IsButtondelete = bool.Parse(BaseResult.tsauthTranfer.DEL_AUTH_YN);
                IsButtoncancel = bool.Parse(BaseResult.tsauthTranfer.CAN_AUTH_YN);
                IsButtoninport = bool.Parse(BaseResult.tsauthTranfer.EXCL_AUTH_YN);
                IsButtonexport = bool.Parse(BaseResult.tsauthTranfer.DNLD_AUTH_YN);
                IsButtonprint = bool.Parse(BaseResult.tsauthTranfer.PRNT_AUTH_YN);
            }
        }
    }
    catch (Exception ex)
    {
        string mes = ex.Message;
    }
    try
    {
        BaseResult = await _admin2Service.Load();
    }
    catch (Exception ex)
    {
        string mes = ex.Message;
    }
}

@{
    ViewData["Title"] = @MES_MVC.Resources.Resource.GetObject(url) + " (" + url + ")";
}

<div class="col s12 m12 l12">
    <div class="card card-default scrollspy">
        <div class="card-content">
            <div class="row">
                <div class="col s12 m12 l3">
                    <h6><b>@MES_MVC.Resources.Resource.GetObject(url) (@url)</b></h6>
                </div>
                <div class="col s12 m12 l9 right-align-md">
                    @if (IsButtonfind)
                    {
                        <button id="Buttonfind" title="@MES_MVC.Resources.Resource.Buttonfind"
                                class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                            <i class="material-icons">search</i> @MES_MVC.Resources.Resource.Buttonfind
                        </button>
                    }

                    @if (IsButtonadd)
                    {
                        <button id="Buttonadd" title="@MES_MVC.Resources.Resource.Buttonadd"
                                class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                            <i class="material-icons">add</i> @MES_MVC.Resources.Resource.Buttonadd
                        </button>
                    }

                    @if (IsButtonsave)
                    {
                        <button id="Buttonsave" title="@MES_MVC.Resources.Resource.Buttonsave"
                                class="btn waves-effect waves-light cyan darken-1" style="margin-right: 10px;">
                            <i class="material-icons">save</i> @MES_MVC.Resources.Resource.Buttonsave
                        </button>
                    }

                    @if (IsButtondelete)
                    {
                        <button id="Buttondelete" title="@MES_MVC.Resources.Resource.Buttondelete"
                                class="btn waves-effect waves-light red darken-1" style="margin-right: 10px;">
                            <i class="material-icons">delete</i> @MES_MVC.Resources.Resource.Buttondelete
                        </button>
                    }


                    <button id="Buttonhelp" title="@MES_MVC.Resources.Resource.Buttonhelp" class="btn waves-effect waves-light green darken-1"
                            style="margin-right: 10px;">
                        <i class="material-icons">help</i>
                    </button>

                    <button id="Buttonclose" title="@MES_MVC.Resources.Resource.Buttonclose" class="btn waves-effect waves-light purple darken-1"><i class="material-icons">close</i> @MES_MVC.Resources.Resource.Buttonclose</button>
                </div>
            </div>
            <div class="row" style="margin:3px;">
                <div class="col s12 m6 l3" style="border: 1px solid black; ">
                    <div class="row header-form">
                        <label>@MES_MVC.Resources.Resource.DbTbl_PermissionGroup</label>
                    </div>
                    <div class="row ">
                        <table id="group_table">
                            <thead>
                                <tr>
                                    <th class="text-center" style=" cursor:pointer;"></th>
                                    <th class="text-center" style=" cursor:pointer;"></th>
                                    <th class="text-center" style=" cursor:pointer;"></th>
                                    <th class="text-center" style=" cursor:pointer;"></th>
                                </tr>
                            </thead>
                            <tbody id="group_table_view">
                                @{
                                    if (BaseResult.ListtsauthTranfer != null && BaseResult.ListtsauthTranfer.Count > 0)
                                    {
                                        int index = 1;
                                        foreach (var item in BaseResult.ListtsauthTranfer)
                                        {
                                            <tr data-auth-idx="@item.AUTH_IDX">
                                                <td>@index</td>
                                                <td>@item.AUTH_ID</td>
                                                <td>@item.AUTH_NM</td>
                                                <td>
                                                    <button class="btn btn-edit btn-small btn-secondary" data-index="${index}" style="padding: 4px; height:20px;width:20px; margin:2px;" title="@MES_MVC.Resources.Resource.ButtonEdit">
                                                        <i class="material-icons">edit</i>
                                                    </button>
                                                </td>
                                            </tr>

                                            index++;
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="3" style="text-align:center;">No data available</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="col s12 m6 l9" style="background-color:honeydew;">
                    <div class="row">
                        <div class="col s12 m4 l4">
                            <div class="row">
                                <div class="col s12 m6 l4">
                                    <label style="display: flex; align-items: center; justify-content: center; gap: 2px; margin: 0;">
                                        @MES_MVC.Resources.Resource.DbTbl_PrimaryMenu
                                    </label>
                                </div>
                                <div class="col s12 m6 l8">
                                    <select id="group_menu_selector" class="form-control browser-default" style="color: black; font-size: 14px;min-height:35px; margin-top:3px; background-color:burlywood;">
                                        <option value="ALL">
                                            ALL
                                        </option>

                                        @{
                                            if (BaseResult.ListtsmenuTranfer != null && BaseResult.ListtsmenuTranfer.Count > 0)
                                            {
                                                int index = 1;
                                                foreach (var item in BaseResult.ListtsmenuTranfer)
                                                {
                                                    <option value="@item.MENU_NM_VIE">
                                                        @item.MENU_NM_EN
                                                    </option>
                                                    index++;
                                                }
                                            }

                                        }
                                    </select>
                                </div>
                            </div>

                        </div>
                    </div>
                    <div class="row">
                        <table id="menu_table">
                            <thead>
                                <tr>
                                    <th style=" cursor:pointer;">
                                        No
                                    </th>
                                    <th style=" cursor:pointer;">
                                        @MES_MVC.Resources.Resource.DbTbl_Link
                                    </th>
                                    <th style=" cursor:pointer;">
                                        @MES_MVC.Resources.Resource.DbTbl_MenuLevel
                                    </th>
                                    <th style=" cursor:pointer;">
                                        English
                                    </th>
                                    <th style=" cursor:pointer;">
                                        Korea
                                    </th>
                                    <th style="cursor:pointer;">
                                        <label style="display: flex; align-items: center; justify-content: center; gap: 2px; margin: 0;">
                                            <input id="check_all_menu" type="checkbox" style="margin:0px;" />
                                            <span>@MES_MVC.Resources.Resource.MML_Menu</span>
                                        </label>
                                    </th>
                                    <th style=" cursor:pointer;">
                                        <label style="display: flex; align-items: center; justify-content: center; gap: 2px; margin: 0;">
                                            <input id="check_all_search" type="checkbox" />
                                            <span>@MES_MVC.Resources.Resource.Buttonfind</span>
                                        </label>
                                    </th>
                                    <th style=" cursor:pointer;">
                                        <label style="display: flex; align-items: center; justify-content: center; gap: 2px; margin: 0;">
                                            <input id="check_all_add" type="checkbox" />
                                            <span>@MES_MVC.Resources.Resource.Buttonadd</span>
                                        </label>
                                    </th>
                                    <th style=" cursor:pointer;">
                                        <label style="display: flex; align-items: center; justify-content: center; gap: 2px; margin: 0;">
                                            <input id="check_all_save" type="checkbox" />
                                            <span>@MES_MVC.Resources.Resource.Buttonsave</span>
                                        </label>
                                    </th>
                                    <th style=" cursor:pointer;">
                                        <label style="display: flex; align-items: center; justify-content: center; gap: 2px; margin: 0;">
                                            <input id="check_all_delete" type="checkbox" />
                                            <span>@MES_MVC.Resources.Resource.Buttondelete</span>
                                        </label>
                                    </th>
                                    <th style=" cursor:pointer;">
                                        <label style="display: flex; align-items: center; justify-content: center; gap: 2px; margin: 0;">
                                            <input id="check_all_cancel" type="checkbox" />
                                            <span>@MES_MVC.Resources.Resource.Buttoncancel</span>
                                        </label>
                                    </th>
                                    <th style=" cursor:pointer;">
                                        <label style="display: flex; align-items: center; justify-content: center; gap: 2px; margin: 0;">
                                            <input id="check_all_import" type="checkbox" />
                                            <span>@MES_MVC.Resources.Resource.Buttoninport</span>
                                        </label>
                                    </th>
                                    <th style=" cursor:pointer;">
                                        <label style="display: flex; align-items: center; justify-content: center; gap: 2px; margin: 0;">
                                            <input id="check_all_export" type="checkbox" />
                                            <span>@MES_MVC.Resources.Resource.Buttonexport</span>
                                        </label>
                                    </th>
                                    <th style=" cursor:pointer;">
                                        <label style="display: flex; align-items: center; justify-content: center; gap: 2px; margin: 0;">
                                            <input id="check_all_print" type="checkbox" />
                                            <span>@MES_MVC.Resources.Resource.Buttonprint</span>
                                        </label>
                                    </th>
                                    <th style=" cursor:pointer;">
                                        <label style="display: flex; align-items: center; justify-content: center; gap: 2px; margin: 0;">
                                            <input id="check_all_ETC1" type="checkbox" />
                                            <span>ETC1</span>
                                        </label>
                                    </th>
                                    <th style=" cursor:pointer;">
                                        <label style="display: flex; align-items: center; justify-content: center; gap: 2px; margin: 0;">
                                            <input id="check_all_ETC2" type="checkbox" />
                                            <span>ETC2</span>
                                        </label>
                                    </th>
                                    <th style=" cursor:pointer;">
                                        <label style="display: flex; align-items: center; justify-content: center; gap: 2px; margin: 0;">
                                            <input id="check_all_ETC3" type="checkbox" />
                                            <span>ETC3</span>
                                        </label>
                                    </th>
                                </tr>
                            </thead>
                            <tbody id="menu_table_view">
                                <!-- Dữ liệu sẽ được đổ tại đây -->
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div id="createModal" class="modal" style="width:600px; height:250px;">
    <div class="modal-content">
        <label id="confirmTitle" class="header-form">@MES_MVC.Resources.Resource.DbTbl_PermissionGroup: @MES_MVC.Resources.Resource.Btn_Create </label>
        <label id="Edit_IDX" class="header-form" ></label>
        <div class="row" style="margin:5px;">
            <div class="row">
                <div class="col s12 s6 l4">
                    <label>@MES_MVC.Resources.Resource.DbTbl_GroupCode :</label>
                </div>
                <div class="col s12 s6 l8">
                    <input id="group_InputCode" type="text" class="form-control" maxlength="80" style="color: black; font-size: 16px; min-height:30px;">
                </div>
            </div>
            <div class="row">
                <div class="col s12 s6 l4">
                    <label>@MES_MVC.Resources.Resource.DbTbl_GroupName :</label>
                </div>
                <div class="col s12 s6 l8">
                    <input id="group_InputName" type="text" class="form-control" maxlength="80" style="color: black; font-size: 16px; min-height:30px;">
                </div>
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <div class="row">
            <div class="col s12 m6 l6">
                <button id="btnSave" title="@MES_MVC.Resources.Resource.Buttonsave"
                        class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                    <i class="material-icons">save</i> @MES_MVC.Resources.Resource.Buttonsave
                </button>
            </div>
            <div class="col s12 m6 l6">
                <button id="btnCancel" title="@MES_MVC.Resources.Resource.Buttoncancel"
                        class="btn waves-effect waves-light red darken-1" style="margin-right: 10px;">
                    <i class="material-icons">cancel</i> @MES_MVC.Resources.Resource.Buttoncancel
                </button>
            </div>
        </div>

    </div>
</div>

<div id="confirmModal" class="modal" style="width:600px; height:250px;">
    <div class="modal-content">
        <h4 id="confirmTitle">@MES_MVC.Resources.Resource.CONFIRM_Delete</h4>
        <p id="confirmMessage" style="font-size:20px;">Bạn có chắc chắn muốn thực hiện thao tác này?</p>
    </div>
    <div class="modal-footer">
        <div class="row">
            <div class="col s12 m6 l6">
                <button id="btn_confirmYes" title="@MES_MVC.Resources.Resource.Buttondelete"
                        class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                    <i class="material-icons">save</i> @MES_MVC.Resources.Resource.Buttondelete
                </button>
            </div>
            <div class="col s12 m6 l6">
                <button id="btn_confirmCancel" title="@MES_MVC.Resources.Resource.Buttoncancel"
                        class="btn waves-effect waves-light red darken-1" style="margin-right: 10px;">
                    <i class="material-icons">cancel</i> @MES_MVC.Resources.Resource.Buttoncancel
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    // Lấy text từ C# resource đưa vào biến JS
    const MessageText = {
        Success: '@MES_MVC.Resources.Resource.SUCCESS_Success',
        Empty: '@MES_MVC.Resources.Resource.ERROR_NoData',
        CannotDelete: '@MES_MVC.Resources.Resource.ERROR_CannotDelete',
        NotSelectOnGrid:'@MES_MVC.Resources.Resource.WARN_NotSelectOnGrid',
        DeleteData: '@MES_MVC.Resources.Resource.CONFIRM_Delete'
    };

    const HeaderText = {
        No: '@MES_MVC.Resources.Resource.DbTbl_ItemNo',
        ID: '@MES_MVC.Resources.Resource.DbTbl_ID',
        GroupCode: '@MES_MVC.Resources.Resource.DbTbl_GroupCode',
        GroupName: '@MES_MVC.Resources.Resource.DbTbl_GroupName',
        Edit: '@MES_MVC.Resources.Resource.DbTbl_PermissionGroup: @MES_MVC.Resources.Resource.ButtonEdit',
        Create: '@MES_MVC.Resources.Resource.DbTbl_PermissionGroup: @MES_MVC.Resources.Resource.Buttonadd',
    };

</script>
<script src="~/Scripts/admin2.js?v=@GlobalHelper.GetVersionScrip("admin2.js")"></script>
