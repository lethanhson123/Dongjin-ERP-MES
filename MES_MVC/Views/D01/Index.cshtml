                                </div>
                                <div class="col s12 m12 l6 text-left">
                                    <label style="font-size:14px;">@MES_MVC.Resources.Resource.DbTbl_ToDate</label>
                                    <input id="tab1_toDate" type="date" class="form-control" style="color: black; font-size: 16px;min-height:30px;"
                                           value="@DateTime.Now.ToString("yyyy-MM-dd")">
                                </div>
                            </div>

                            <div class="col s12 m12 l2">
