                                        <th onclick="sortTable('Table1',8)" style="min-width:60px; cursor:pointer;">
                                            @MES_MVC.Resources.Resource.DbTbl_StockQty
                                        </th>
                                        <th onclick="sortTable('Table1',9)" style="min-width:60px; cursor:pointer;">
                                            @MES_MVC.Resources.Resource.DbTbl_POQty
