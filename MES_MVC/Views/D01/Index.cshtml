                                <tbody id="DataGridView1">
                                    <!-- Dữ liệu sẽ được đổ tại đây -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="row" id="Tag002">
                    <div class="col s12 m6 l12 card-panel light-blue lighten-4">
                        <div class="row" style="margin:5px;">
                            <div class="col s12 m6 l4">
                                <div class="col s12 m12 l3 text-left">
                                    <label>@MES_MVC.Resources.Resource.DbTbl_Year</label>
                                    <input id="tab2_year" type="number" class="form-control" style="color: black; min-height:30px;"
                                           value="2025">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col s12 m6 l12 card-panel lighten-4">
                        <div class="row m-1 p-1" style="margin:3px">
                            <div class="KhungOverflow">
                                <table class="responsive-table" id="Table2">
                                    <thead class="sticky-header">
                                        <tr>
                                            <th onclick="sortTable('Table2',0)" style="cursor:pointer;">No</th>
                                            <th onclick="sortTable('Table2',1)" style="cursor:pointer;">Model</th>
                                            <th onclick="sortTable('Table2',2)" style="cursor:pointer;">Product Count</th>
                                            <th onclick="sortTable('Table2',3)" style="cursor:pointer;">PO Quantity</th>
                                            <th onclick="sortTable('Table2',4)" style="cursor:pointer;">Actual Quantity</th>
                                            <th onclick="sortTable('Table2',5)" style="cursor:pointer;">Achievement Rate (%)</th>
                                            <th onclick="sortTable('Table2',6)" style="cursor:pointer;">Total Sales</th>

                                            <!-- Dữ liệu theo tháng -->
                                            @for (int i = 1; i <= 12; i++)
                                            {
                                                var month = i.ToString("D2");
                                                <th onclick="sortTable('Table2', @(i * 3 + 4))" style="cursor:pointer;">PO_@month</th>
                                                <th onclick="sortTable('Table2', @(i * 3 + 5))" style="cursor:pointer;">ACT_@month</th>
                                                <th onclick="sortTable('Table2', @(i * 3 + 6))" style="cursor:pointer;">Sales_@month</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody id="DataGridView2">
                                        <!-- Dữ liệu sẽ được đổ tại đây -->
                                    </tbody>
                                </table>

                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<script>
      const sortState = {};
    function sortTable(tableId, columnIndex) {
        const table = document.getElementById(tableId);
        const tbody = table.tBodies[0];
        const rows = Array.from(tbody.rows);
        // Key duy nhất cho từng bảng và cột
        const key = tableId + "_" + columnIndex;
        const currentDirection = sortState[key] || 'asc';

        rows.sort((a, b) => {
            let cellA = a.cells[columnIndex].innerText.trim().toLowerCase();
            let cellB = b.cells[columnIndex].innerText.trim().toLowerCase();
            // So sánh số nếu có thể
            const isNumeric = !isNaN(cellA) && !isNaN(cellB);
            if (isNumeric) {
                cellA = parseFloat(cellA);
                cellB = parseFloat(cellB);
            }
            if (cellA < cellB) return currentDirection === 'asc' ? -1 : 1;
            if (cellA > cellB) return currentDirection === 'asc' ? 1 : -1;
            return 0;
        });
        // Gắn lại thứ tự
        while (tbody.firstChild) {
            tbody.removeChild(tbody.firstChild);
        }
        rows.forEach(row => tbody.appendChild(row));
        // Lưu trạng thái lần sau đảo chiều
        sortState[key] = currentDirection === 'asc' ? 'desc' : 'asc';
    };

        const localizedText = {
        search: '@MES_MVC.Resources.Resource.Btn_Search',
        WrongCode: '@MES_MVC.Resources.Resource.ERROR_NotExisted',
        WrongProduct: '@MES_MVC.Resources.Resource.ERROR_WrongProductCode',      
        Success: '@MES_MVC.Resources.Resource.SUCCESS_Success',
        Empty: '@MES_MVC.Resources.Resource.ERROR_NoData',
    };

</script>
<script src="~/Scripts/D01.js?v=@version"></script>

