                                        <th onclick="sortTable('Table1',5)" style="min-width:60px; cursor:pointer;">
                                            @MES_MVC.Resources.Resource.DbTbl_Model
                                        </th>
                                        <th onclick="sortTable('Table1',6)" style="min-width:90px; cursor:pointer;">
                                            @MES_MVC.Resources.Resource.DbTbl_Group
