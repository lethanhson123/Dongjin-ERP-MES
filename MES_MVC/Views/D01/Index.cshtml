                                        <th onclick="sortTable('Table1',10)" style="min-width:60px; cursor:pointer;">
                                            @MES_MVC.Resources.Resource.DbTbl_SaleQty
                                        </th>
                                        <th onclick="sortTable('Table1',11)" style="min-width:60px; cursor:pointer;">
                                            @MES_MVC.Resources.Resource.DbTbl_Cost
                                        </th>
                                        <th onclick="sortTable('Table1',12)" style="min-width:60px; cursor:pointer;">
                                            @MES_MVC.Resources.Resource.DbTbl_SaleCost
