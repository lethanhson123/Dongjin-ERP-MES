                                <input type="text" id="tab1_PartNo" class="form-control" maxlength="80" style="color: black; font-size: 16px; min-height:30px;" autocomplete="off">
                            </div>
                            <div class="col s12 m12 l2">
                                <label class="input100" style="color:black; font-size:14px">@MES_MVC.Resources.Resource.DbTbl_Model</label>
                                <input type="text" id="tab1_model" class="form-control" maxlength="80" style="color: black; font-size: 16px; min-height:30px;" autocomplete="off">
                            </div>
                        </div>
                    </div>

                    <div class="row m-1 p-1">
                        <div class="KhungOverflow">
                            <table class="responsive-table" id="Table1">
                                <thead class="sticky-header">
                                    <tr>
                                        <th onclick="sortTable('Table1',0)" style="min-width:100px; cursor:pointer;">
