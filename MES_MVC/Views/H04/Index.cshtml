@inject IMAINService _MAINService
@inject CookieHelper CookieHelper
@inject IH04Service _H04Service
@{
    string version = GlobalHelper.InitializationDateTimeCode;
    bool IsButtonfind = false, IsButtonadd = false, IsButtonsave = false, IsButtondelete = false,
         IsButtoncancel = false, IsButtoninport = false, IsButtonexport = false, IsButtonprint = false;

    BaseResult BaseResult = new BaseResult();
    BaseParameter BaseParameter = new BaseParameter();
    string url = "H04";
    try
    {
        BaseParameter.USER_IDX = CookieHelper.GetCookie(GlobalHelper.USER_IDX) ?? string.Empty;
        BaseResult = await _MAINService.Main_Shown(BaseParameter);
        if (BaseResult.ListtsauthTranfer != null)
        {
            BaseResult.tsauthTranfer = BaseResult.ListtsauthTranfer.Where(o => o.SCRN_PATH == url).FirstOrDefault();
            if (BaseResult.tsauthTranfer != null)
            {
                IsButtonfind = bool.Parse(BaseResult.tsauthTranfer.IQ_AUTH_YN);
                IsButtonadd = bool.Parse(BaseResult.tsauthTranfer.RGST_AUTH_YN);
                IsButtonsave = bool.Parse(BaseResult.tsauthTranfer.MDFY_AUTH_YN);
                IsButtondelete = bool.Parse(BaseResult.tsauthTranfer.DEL_AUTH_YN);
                IsButtoncancel = bool.Parse(BaseResult.tsauthTranfer.CAN_AUTH_YN);
                IsButtoninport = bool.Parse(BaseResult.tsauthTranfer.EXCL_AUTH_YN);
                IsButtonexport = bool.Parse(BaseResult.tsauthTranfer.DNLD_AUTH_YN);
                IsButtonprint = bool.Parse(BaseResult.tsauthTranfer.PRNT_AUTH_YN);
            }
        }
    }
    catch (Exception ex)
    {
        string mes = ex.Message;
    }
    try
    {
        BaseResult = await _H04Service.Load();
    }
    catch (Exception ex)
    {
        string mes = ex.Message;
    }
}

@{
    ViewData["Title"] = MES_MVC.Resources.Resource.GetObject(url) + " (" + url + ")";
}

<div class="col s12 m12 l12">
    <div class="card card-default scrollspy">
        <div class="card-content">
            <div class="row">
                <div class="col s12 m12 l3">
                    <h6><b>@MES_MVC.Resources.Resource.GetObject(url) (@url)</b></h6>
                </div>
                <div class="col s12 m12 l9 right-align-md">
                    <button @(IsButtonfind ? "" : "Disabled") id="Buttonfind" title="@MES_MVC.Resources.Resource.Buttonfind" class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                        <i class="material-icons">search</i> @MES_MVC.Resources.Resource.Buttonfind
                    </button>
                    <button @(IsButtonadd ? "" : "Disabled") id="Buttonadd" title="@MES_MVC.Resources.Resource.Buttonadd" class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                        <i class="material-icons">add</i> @MES_MVC.Resources.Resource.Buttonadd
                    </button>
                    <button @(IsButtonsave ? "" : "Disabled") id="Buttonsave" title="@MES_MVC.Resources.Resource.Buttonsave" class="btn waves-effect waves-light cyan darken-1" style="margin-right: 10px;">
                        <i class="material-icons">save</i> @MES_MVC.Resources.Resource.Buttonsave
                    </button>
                    <button @(IsButtondelete ? "" : "Disabled") id="Buttondelete" title="@MES_MVC.Resources.Resource.Buttondelete" class="btn waves-effect waves-light red darken-1" style="margin-right: 10px;">
                        <i class="material-icons">delete</i> @MES_MVC.Resources.Resource.Buttondelete
                    </button>
                    <button @(IsButtoncancel ? "" : "Disabled") id="Buttoncancel" title="@MES_MVC.Resources.Resource.Buttoncancel" class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                        <i class="material-icons">error</i> @MES_MVC.Resources.Resource.Buttoncancel
                    </button>
                    <button @(IsButtoninport ? "" : "Disabled") id="Buttoninport" title="@MES_MVC.Resources.Resource.Buttoninport" class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                        <i class="material-icons">cloud_upload</i> @MES_MVC.Resources.Resource.Buttoninport
                    </button>
                    <button @(IsButtonexport ? "" : "Disabled") id="Buttonexport" title="@MES_MVC.Resources.Resource.Buttonexport" class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                        <i class="material-icons">cloud_download</i> @MES_MVC.Resources.Resource.Buttonexport
                    </button>
                    <button @(IsButtonprint ? "" : "Disabled") id="Buttonprint" title="@MES_MVC.Resources.Resource.Buttonprint" class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                        <i class="material-icons">print</i> @MES_MVC.Resources.Resource.Buttonprint
                    </button>
                    <button id="Buttonhelp" title="@MES_MVC.Resources.Resource.Buttonhelp" class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                        <i class="material-icons">help</i>
                    </button>
                    <button id="Buttonclose" title="@MES_MVC.Resources.Resource.Buttonclose" class="btn waves-effect waves-light purple darken-1" style="margin-right: 10px;">
                        <i class="material-icons">close</i> @MES_MVC.Resources.Resource.Buttonclose
                    </button>
                </div>
            </div>
            <div class="row">
                <div class="col s12 m12 l12">
                    <ul class="tabs">
                        <li class="tab col s6"><a href="#TabPage1">Overall Status</a></li>
                        <li class="tab col s6"><a href="#TabPage2">The Details</a></li>
                    </ul>
                    <!-- Tab 1: Tổng hợp, biểu đồ & bảng -->
                    <div id="TabPage1">
                        <div class="row">
                            <div class="col s12 m12 l12 chart-container">
                                <canvas id="Chart" style="height: 550px;"></canvas>
                            </div>
                            <div class="col s12 m12 l12 KhungOverflow10">
                                <table class="responsive-table" id="DataGridView2Table">
                                    <thead class="sticky-header">
                                        <tr>
                                            <th>TIME</th>
                                            <th>ZA801</th>
                                            <th>ZA802</th>
                                            <th>ZA803</th>
                                            <th>ZA804</th>
                                            <th>ZA805</th>
                                            <th>ZA806</th>
                                            <th>ZA807</th>
                                            <th>ZA808</th>
                                            <th>ZA809</th>
                                            <th>ZA810</th>
                                            <th>SUM</th>
                                        </tr>
                                    </thead>
                                    <tbody id="DataGridView2"></tbody>
                                </table>
                            </div>
                            <div class="col s12 m12 l12 KhungOverflow10">
                                <table class="responsive-table" id="DataGridView3Table">
                                    <thead class="sticky-header">
                                        <tr>
                                            <th>CODE</th>
                                            <th>ZA801</th>
                                            <th>ZA802</th>
                                            <th>ZA803</th>
                                            <th>ZA804</th>
                                            <th>ZA805</th>
                                            <th>ZA806</th>
                                            <th>ZA807</th>
                                            <th>ZA808</th>
                                            <th>ZA809</th>
                                            <th>ZA810</th>
                                            <th>SUM</th>
                                        </tr>
                                    </thead>
                                    <tbody id="DataGridView3"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <!-- Tab 2: Chi tiết, filter, bảng, panel -->
                    <div id="TabPage2">
                        <div class="row input-section">
                            <div class="col s12 m12 l12 card-panel green lighten-4">
                                <div style="display: flex; align-items: center; gap: 15px; flex-wrap: wrap;">
                                    <!-- Tên thiết bị -->
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <label for="ComboBox1" style="font-weight: bold; white-space: nowrap;">설비명:</label>
                                        <select id="ComboBox1" class="browser-default form-select" style="min-width: 120px;"></select>
                                    </div>
                                    <!-- Mã không hoạt động -->
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <label for="ComboBox2" style="font-weight: bold; white-space: nowrap;">비가동 코드:</label>
                                        <select id="ComboBox2" class="browser-default form-select" style="min-width: 120px;"></select>
                                    </div>
                                    <!-- Ngày 1 -->
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <label for="DateTimePicker1" style="font-weight: bold; white-space: nowrap;">날짜:</label>
                                        <input id="DateTimePicker1" type="date" class="form-control" style="height: 30px;">
                                    </div>
                                    <!-- Giờ 1 -->
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <label for="ComboBox3" style="font-weight: bold; white-space: nowrap;">Giờ:</label>
                                        <select id="ComboBox3" class="browser-default form-select" style="min-width: 70px;">
                                            @for (int i = 0; i < 24; i++)
                                            {
                                                var h = i.ToString("D2") + ":00";
                                                <option value="@h">@h</option>
                                            }
                                        </select>
                                    </div>
                                    <!-- Ngày 2 -->
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <label for="DateTimePicker2" style="font-weight: bold; white-space: nowrap;">날짜:</label>
                                        <input id="DateTimePicker2" type="date" class="form-control" style="height: 30px;">
                                    </div>
                                    <!-- Giờ 2 -->
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <label for="ComboBox4" style="font-weight: bold; white-space: nowrap;">Giờ:</label>
                                        <select id="ComboBox4" class="browser-default form-select" style="min-width: 70px;">
                                            @for (int i = 0; i < 24; i++)
                                            {
                                                var h = i.ToString("D2") + ":00";
                                                <option value="@h">@h</option>
                                            }
                                        </select>
                                    </div>
                                    <!-- Người dùng -->
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <label for="TextBox1" style="font-weight: bold; white-space: nowrap;">사용자:</label>
                                        <input id="TextBox1" type="text" class="form-control" style="height: 30px; min-width: 100px;">
                                    </div>
                                    <!-- Checkbox -->
                                    <div style="display: flex; align-items: center; gap: 5px;">
                                        <input type="checkbox" id="CheckBox1" class="form-check-input" />
                                        <span>날짜무시</span>
                                    </div>
                                    <!-- Nút Manual -->
                                    <div style="margin-left: auto;">
                                        <button id="Button1" title="Toggle Panel" class="btn waves-effect waves-light blue darken-1">
                                            <i class="material-icons">visibility</i> Manual
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                          
                            <!-- Center column for DataGridView1 -->
                            <div class="col s12 m6 l7">
                                <div class="KhungOverflow70">
                                    <table class="responsive-table" id="DataGridView1Table">
                                        <thead class="sticky-header">
                                            <tr>
                                                <th style="width: 100px;">CODE</th>
                                                <th style="width: 100px;">DATE</th>
                                                <th style="width: 120px;">S_USER</th>
                                                <th style="width: 100px;">MC_NAME</th>
                                                <th style="width: 180px;">S_TIME</th>
                                                <th style="width: 180px;">E_TIME</th>
                                                <th style="width: 100px;">TIME(S)</th>
                                                <th style="width: 100px;">TIME(M)</th>
                                                <th style="width: 100px;">E_USER</th>
                                                <th style="width: 150px;">Contents</th>
                                            </tr>
                                        </thead>
                                        <tbody id="DataGridView1"></tbody>
                                    </table>
                                </div>
                            </div>
                            <!-- Right column for Panel2 -->
                            <div class="col s12 m3 l3">
                                <div id="Panel2" style="display: none; height: 800px; overflow-y: auto;" class="card-panel">
                                    <h6 class="center-align"><b>비가동 정보</b></h6>
                                    <table class="striped">
                                        <tr><td><b>CODE</b></td><td>비가동 코드</td></tr>
                                        <tr><td><b>DATE</b></td><td>등록날짜</td></tr>
                                        <tr><td><b>S_USER</b></td><td>비가동 시작한 사용자</td></tr>
                                        <tr><td><b>MC_NAME</b></td><td>Thiết bị</td></tr>
                                        <tr><td><b>S_TIME</b></td><td>비가동 시작 시간</td></tr>
                                        <tr><td><b>E_TIME</b></td><td>비가동 종료 시간</td></tr>
                                        <tr><td><b>TIME(S)</b></td><td>비가동을 초로 환산</td></tr>
                                        <tr><td><b>TIME(M)</b></td><td>TIME(S) / 60</td></tr>
                                        <tr><td><b>E_USER</b></td><td>비가동 종료한 사용자</td></tr>
                                    </table>
                                    <div class="divider" style="margin: 15px 0;"></div>
                                    <p>* S_USER = E_USER 다르면 시스템에서 이상발생 조치로 비가동시간이 달라짐</p>
                                    <p>* 시간으로 계산하기 때문에 조금의 오차는 있음</p>
                                    <p>* 단, TIME(S) 기준값으로 절대 변하지 않음</p>
                                    <div class="divider" style="margin: 15px 0;"></div>
                                    <h6 class="center-align"><b>비가동코드</b></h6>
                                    <table class="striped">
                                        <tr><td><b>S</b></td><td>설비준비 (Chuẩn bị thiết bị)</td></tr>
                                        <tr><td><b>I</b></td><td>자재결품 (Thiếu vật liệu)</td></tr>
                                        <tr><td><b>Q</b></td><td>품질문제 (Vấn đề chất lượng)</td></tr>
                                        <tr><td><b>M</b></td><td>설비고장 (Hỏng thiết bị)</td></tr>
                                        <tr><td><b>T</b></td><td>교육/회의 (Đào tạo/Họp)</td></tr>
                                        <tr><td><b>L</b></td><td>식사시간 (Thời gian ăn)</td></tr>
                                        <tr><td><b>E</b></td><td>기타 (Khác)</td></tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div> <!-- End TabPage2 -->
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="~/Scripts/H04.js?v=@version"></script>
<style>
    .sticky-header th {
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .browser-default {
        height: 30px !important;
        margin: 2px 0 !important;
    }

   

  
</style>
