<!-- Modal for production data -->
<div id="H00_LISTModal" class="modal modal-fixed-footer" style="width: 95%; height: 85%;">
    <div class="modal-content">
        <div class="modal-header-info">
            <div class="info-row">
                <span><strong>가동율:</strong> (작업 시간 - (비가동 - L, T, M 비가동)) / 작업시간</span>
                <span style="margin-left: 30px;"><strong>비가동:</strong> L : 식사시간, T : 교육시간, M : 설비교정</span>
            </div>
            <div class="info-row">
                <span><strong>UPH:</strong> 생산수량 / (작업시간 - 비가동)</span>
            </div>
        </div>

        <div class="KhungOverflow">
            <table class="responsive-table" id="DataGridView1Table">
                <thead class="sticky-header">
                    <tr>
                        <th>DATE</th>
                        <th>MC_NO</th>
                        <th>시작시간</th>
                        <th>종료시간</th>
                        <th>QTY</th>
                        <th>STOP_TIME</th>
                        <th>STOP_TIME(L,T 제외)</th>
                        <th>WORK_TIME</th>
                        <th>Operating rate</th>
                        <th>UPH</th>
                    </tr>
                </thead>
                <tbody id="DataGridView1">
                </tbody>
            </table>
        </div>
    </div>
    <div class="modal-footer">
        <a href="#!" class="modal-close waves-effect waves-green btn-flat">Close</a>
    </div>
</div>

