<!-- Custom CSS -->
<style>
    /* Main Navigation Buttons */
    .mes-nav-btn {
        background-color: #666 !important;
        color: white !important;
        font-weight: bold;
        text-transform: uppercase;
        min-width: 120px;
    }

    .mes-nav-active {
        background-color: #000 !important;
    }

    /* Sub Navigation Tabs */
    .mes-sub-tabs {
        background-color: #f5f5f5;
        margin-bottom: 0;
        border-bottom: 1px solid #ddd;
    }

    .mes-tab-sub {
        background-color: #e0e0e0 !important;
        color: #333 !important;
        font-weight: 900 !important;
        text-transform: uppercase;
        border-right: 1px solid #ccc;
    }

        .mes-tab-sub.active {
            background-color: white !important;
            color: #333 !important;
            border-bottom: 2px solid #26a69a;
            font-weight: 900 !important;
        }

    /* Table Styles */
    .mes-report-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
    }

    .mes-table-header {
        background-color: #333;
        color: white;
    }

    .mes-th {
        background-color: #333 !important;
        color: white !important;
        padding: 12px 8px;
        text-align: center;
        font-weight: bold;
        border: 1px solid #555;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .mes-table-body tr {
        border-bottom: 1px solid #ddd;
    }

        .mes-table-body tr:hover {
            background-color: #f5f5f5;
        }

    .mes-table-body td {
        padding: 8px;
        text-align: center;
        border: 1px solid #ddd;
        font-size: 20px;
    }

    /* Special row styling for ALL rows */
    .mes-table-body tr.all-row {
        background-color: #696969 !important;
        color: white;
    }

        .mes-table-body tr.all-row:hover {
            background-color: #555 !important;
        }

    /* Highlight columns (LEAD Ratio and ACT Ratio) */
    .mes-table-body td.highlight-yellow {
        color: #FFD700 !important;
        font-weight: bold;
    }

   
    .mes-tab-content {
        margin-top: 10px;
    }

    .mes-sub-content {
        margin-top: 0;
    }

    .right-align-md {
        text-align: right;
    }

    .p-0 {
        padding: 0 !important;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .mes-report-table

    {
        font-size: 10px;
    }

    .mes-th, .mes-table-body td {
        padding: 6px 4px;
    }

  
    .mes-nav-btn {
        min-width: 80px;
        font-size: 12px;
    }

    }
</style>

<script src="~/Scripts/MES_REPORT.js?v=@version"></script>