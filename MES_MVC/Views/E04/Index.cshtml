@inject IMAINService _MAINService
@inject CookieHelper CookieHelper
@inject IE04Service _E04Service
@{
    string version = GlobalHelper.InitializationDateTimeCode;
    bool IsButtonfind = false;
    bool IsButtonadd = false;
    bool IsButtonsave = false;
    bool IsButtondelete = false;
    bool IsButtoncancel = false;
    bool IsButtoninport = false;
    bool IsButtonexport = false;
    bool IsButtonprint = false;

    BaseResult BaseResult = new BaseResult();
    BaseParameter BaseParameter = new BaseParameter();
    string url = "E04";
    try
    {
        BaseParameter.USER_IDX = CookieHelper.GetCookie(GlobalHelper.USER_IDX) ?? string.Empty;
        BaseResult = await _MAINService.Main_Shown(BaseParameter);
        if (BaseResult.ListtsauthTranfer != null)
        {
            BaseResult.tsauthTranfer = BaseResult.ListtsauthTranfer.Where(o => o.SCRN_PATH == url).FirstOrDefault();
            if (BaseResult.tsauthTranfer != null)
            {
                IsButtonfind = bool.Parse(BaseResult.tsauthTranfer.IQ_AUTH_YN);
                IsButtonadd = bool.Parse(BaseResult.tsauthTranfer.RGST_AUTH_YN);
                IsButtonsave = bool.Parse(BaseResult.tsauthTranfer.MDFY_AUTH_YN);
                IsButtondelete = bool.Parse(BaseResult.tsauthTranfer.DEL_AUTH_YN);
                IsButtoncancel = bool.Parse(BaseResult.tsauthTranfer.CAN_AUTH_YN);
                IsButtoninport = bool.Parse(BaseResult.tsauthTranfer.EXCL_AUTH_YN);
                IsButtonexport = bool.Parse(BaseResult.tsauthTranfer.DNLD_AUTH_YN);
                IsButtonprint = bool.Parse(BaseResult.tsauthTranfer.PRNT_AUTH_YN);
            }
        }
    }
    catch (Exception ex)
    {
        string mes = ex.Message;
    }
}

@{
    ViewData["Title"] = "Maintenance History Management (" + url + ")";
}

<div class="col s12 m12 l12">
    <div class="card card-default scrollspy">
        <div class="card-content">
            <div class="row">
                <div class="col s12 m12 l3">
                    <h6><b>Maintenance History (@url)</b></h6>
                </div>
                <div class="col s12 m12 l9 right-align-md">
                    <button @(IsButtonfind ? "" : "Disabled") id="Buttonfind" title="Search" class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                        <i class="material-icons">search</i> Search
                    </button>

                    <button @(IsButtonadd ? "" : "Disabled") id="Buttonadd" title="Add New" class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                        <i class="material-icons">add</i> Add
                    </button>

                    <button @(IsButtondelete ? "" : "Disabled") id="Buttondelete" title="Delete" class="btn waves-effect waves-light red darken-1" style="margin-right: 10px;">
                        <i class="material-icons">delete</i> Delete
                    </button>

                    <button @(IsButtonexport ? "" : "Disabled") id="Buttonexport" title="Export" class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                        <i class="material-icons">cloud_download</i> Export
                    </button>

                    <button @(IsButtonprint ? "" : "Disabled") id="Buttonprint" title="Print" class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                        <i class="material-icons">print</i> Print
                    </button>

                    <button id="Buttonhelp" title="Help" class="btn waves-effect waves-light green darken-1" style="margin-right: 10px;">
                        <i class="material-icons">help</i>
                    </button>

                    <button id="Buttonclose" title="Close" class="btn waves-effect waves-light purple darken-1">
                        <i class="material-icons">close</i> Close
                    </button>
                </div>
            </div>

            <div class="row">
                <div class="col s12 m6 l2">
                    <label for="FilterFromDate">Từ ngày</label>
                    <input id="FilterFromDate" type="date" class="form-control" />
                </div>
                <div class="col s12 m6 l2">
                    <label for="FilterToDate">Đến ngày</label>
                    <input id="FilterToDate" type="date" class="form-control" />
                </div>
                <div class="col s12 m6 l3">
                    <label for="FilterMachine">Máy</label>
                    <select id="FilterMachine" class="form-control browser-default">
                        <option value="">-- Tất cả --</option>
                    </select>
                </div>
                <div class="col s12 m6 l3">
                    <label for="SearchBox">Tìm kiếm</label>
                    <input id="SearchBox" type="text" class="form-control" placeholder="Tìm kiếm (Máy, Người sửa, Nội dung lỗi, Giải pháp...)" />
                </div>
                <div class="col s12 m6 l2">
                    <label>Tổng số dòng</label>
                    <div class="form-control center-align" style="font-weight: bold; background-color: #e3f2fd; color: #1976d2; padding: 8px;">
                        <i class="material-icons tiny" style="vertical-align: middle;">view_list</i>
                        <span id="TotalRecords">0</span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col s12">
                    <div class="KhungOverflow70">
                        <table id="DataGridView1" class="highlight responsive-table">
                            <thead class="sticky-header">
                                <tr>
                                    <th>Action</th>
                                    <th>ID</th>
                                    <th>Tool/Machine</th>
                                    <th>Type</th>
                                    <th>Status</th>
                                    <th>Solution</th>
                                    <th>Spare Parts</th>
                                    <th>Maintained By</th>
                                    <th>Start Date</th>
                                    <th>End Date</th>
                                    <th>Duration (min)</th>
                                    <th>Notes</th>
                                    <th>Update Date</th>
                                    <th>Update User</th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal dùng chung cho Add và Edit -->
