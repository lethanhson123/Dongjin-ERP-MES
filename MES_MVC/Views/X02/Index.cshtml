@inject IMAINService _MAINService
@inject CookieHelper CookieHelper
@inject IX02Service _X02Service
@{
    string version = GlobalHelper.InitializationDateTimeCode;
    bool IsButtonfind = false;
    bool IsButtonadd = false;
    bool IsButtonsave = false;
    bool IsButtondelete = false;
    bool IsButtoncancel = false;
    bool IsButtoninport = false;
    bool IsButtonexport = false;
    bool IsButtonprint = false;

    BaseResult BaseResult = new BaseResult();
    BaseParameter BaseParameter = new BaseParameter();
    string url = "X02";
    try
    {
        //truyền biến User ID thay thê cho Cookeis đẻ lấy phan quyền action cho button
        BaseParameter.USER_IDX = CookieHelper.GetCookie(GlobalHelper.USER_IDX) ?? string.Empty;
        BaseResult = await _MAINService.Main_Shown(BaseParameter);
        if (BaseResult.ListtsauthTranfer != null)
        {
            BaseResult.tsauthTranfer = BaseResult.ListtsauthTranfer.Where(o => o.SCRN_PATH == url).FirstOrDefault();
            if (BaseResult.tsauthTranfer != null)
            {
                IsButtonfind = bool.Parse(BaseResult.tsauthTranfer.IQ_AUTH_YN);
                IsButtonadd = bool.Parse(BaseResult.tsauthTranfer.RGST_AUTH_YN);
                IsButtonsave = bool.Parse(BaseResult.tsauthTranfer.MDFY_AUTH_YN);
                IsButtondelete = bool.Parse(BaseResult.tsauthTranfer.DEL_AUTH_YN);
                IsButtoncancel = bool.Parse(BaseResult.tsauthTranfer.CAN_AUTH_YN);
                IsButtoninport = bool.Parse(BaseResult.tsauthTranfer.EXCL_AUTH_YN);
                IsButtonexport = bool.Parse(BaseResult.tsauthTranfer.DNLD_AUTH_YN);
                IsButtonprint = bool.Parse(BaseResult.tsauthTranfer.PRNT_AUTH_YN);
            }
        }
    }
    catch (Exception ex)
    {
        string mes = ex.Message;
    }
    try
    {
        BaseResult = await _X02Service.Load();
    }
    catch (Exception ex)
    {
        string mes = ex.Message;
    }
}

@{
    ViewData["Title"] = @MES_MVC.Resources.Resource.GetObject(url) + " (" + url + ")";
}

<div class="col s12 m12 l12">
    <div class="card card card-default scrollspy">
        <div class="card-content">
            <div class="row">
                <div class="col s12 m12 l3">
                    <h6><b>Blade List Management (@url)</b></h6>
                </div>
                <div class="col s12 m12 l9 right-align-md">
                    <button @(IsButtonfind ? "" : "Disabled") id="Buttonfind" title="@MES_MVC.Resources.Resource.Buttonfind" class="btn waves-effect waves-light green darken-1"
                            style="margin-right: 10px;">
                        <i class="material-icons">search</i> @MES_MVC.Resources.Resource.Buttonfind
                    </button>

                    <button @(IsButtonadd ? "" : "Disabled") id="Buttonadd" title="@MES_MVC.Resources.Resource.Buttonadd" class="btn waves-effect waves-light green darken-1"
                            style="margin-right: 10px;">
                        <i class="material-icons">add</i> @MES_MVC.Resources.Resource.Buttonadd
                    </button>

                    <button @(IsButtonsave ? "" : "Disabled") id="Buttonsave" title="@MES_MVC.Resources.Resource.Buttonsave" class="btn waves-effect waves-light cyan darken-1"
                            style="margin-right: 10px;">
                        <i class="material-icons">save</i> @MES_MVC.Resources.Resource.Buttonsave
                    </button>

                    <button @(IsButtondelete ? "" : "Disabled") id="Buttondelete" title="@MES_MVC.Resources.Resource.Buttondelete" class="btn waves-effect waves-light red darken-1"
                            style="margin-right: 10px;">
                        <i class="material-icons">delete</i> @MES_MVC.Resources.Resource.Buttondelete
                    </button>

                    <button @(IsButtoncancel ? "" : "Disabled") id="Buttoncancel" title="@MES_MVC.Resources.Resource.Buttoncancel" class="btn waves-effect waves-light green darken-1"
                            style="margin-right: 10px;">
                        <i class="material-icons">error</i> @MES_MVC.Resources.Resource.Buttoncancel
                    </button>

                    <button @(IsButtoninport ? "" : "Disabled") id="Buttoninport" title="@MES_MVC.Resources.Resource.Buttoninport" class="btn waves-effect waves-light green darken-1"
                            style="margin-right: 10px;">
                        <i class="material-icons">cloud_upload</i> @MES_MVC.Resources.Resource.Buttoninport
                    </button>

                    <button @(IsButtonexport ? "" : "Disabled") id="Buttonexport" title="@MES_MVC.Resources.Resource.Buttonexport" class="btn waves-effect waves-light green darken-1"
                            style="margin-right: 10px;">
                        <i class="material-icons">cloud_download</i> @MES_MVC.Resources.Resource.Buttonexport
                    </button>

                    <button @(IsButtonprint ? "" : "Disabled") id="Buttonprint" title="@MES_MVC.Resources.Resource.Buttonprint" class="btn waves-effect waves-light green darken-1"
                            style="margin-right: 10px;">
                        <i class="material-icons">print</i> @MES_MVC.Resources.Resource.Buttonprint
                    </button>

                    <button id="Buttonhelp" title="@MES_MVC.Resources.Resource.Buttonhelp" class="btn waves-effect waves-light green darken-1"
                            style="margin-right: 10px;">
                        <i class="material-icons">help</i>
                    </button>

                    <button id="Buttonclose" title="@MES_MVC.Resources.Resource.Buttonclose" class="btn waves-effect waves-light purple darken-1"><i class="material-icons">close</i> @MES_MVC.Resources.Resource.Buttonclose</button>
                </div>
            </div>
            <div class="row">
                <div class="col s12 m6 l4">
                    <ul class="tabs">
                        <li class="tab col s4 p-0">
                            <a id="ATag001" class="active p-0" href="#Tab001">Blade List</a>
                        </li>
                        <li class="tab col s4 p-0">
                            <a id="ATag002" class="p-0" href="#Tab002">Scan In</a>
                        </li>
                        <li class="tab col s4 p-0">
                            <a id="ATag003" class="p-0" href="#Tab003">Scan Out</a>
                        </li>
                    </ul>
                </div>
                <div class="col s12 m6 l8">
                </div>
            </div>
            <div id="Tab001" class="col s12">
                <!-- Card Panel tìm kiếm -->
                <div class="row">
                    <div class="col s12 m12 l12 card-panel blue lighten-4">

                        <div class="col s12 m6 l3">
                            <div>
                                <label>Part Name</label>
                                <input id="search_PartName" type="text" class="form-control">
                            </div>
                        </div>
                        <div class="col s12 m6 l3">
                            <div>
                                <label>Spec</label>
                                <input id="search_Spec" type="text" class="form-control">
                            </div>
                        </div>
                        <div class="col s12 m6 l3">
                            <div>
                                <label>Location</label>
                                <input id="search_Location" type="text" class="form-control">
                            </div>
                        </div>
                        <div class="col s12 m6 l3">
                        </div>

                    </div>
                </div>

                <!-- Card Panel thông tin phụ tùng -->
                <div class="row">
                    <div class="col s12 m12 l12 card-panel green lighten-4">
                        <div class="col s12 m6 l2">
                            <div>
                                <label>PartName</label>
                                <input id="txt_PartName" type="text" class="form-control">
                            </div>
                        </div>
                        <div class="col s12 m6 l2">
                            <div>
                                <label>Spec</label>
                                <input id="txt_Spec" type="text" class="form-control">
                            </div>
                        </div>
                        <div class="col s12 m6 l2">
                            <div>
                                <label>Location</label>
                                <input id="txt_Location" type="text" class="form-control">
                            </div>
                        </div>
                        <div class="col s12 m6 l2">
                            <div>
                                <label>Safety Stock</label>
                                <input id="txt_SafetyStock" type="text" class="form-control">
                            </div>
                        </div>
                        <div class="col s12 m6 l2">
                            <div>
                                <label>Description</label>
                                <input id="txt_Description" type="text" class="form-control">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Spare Parts Table -->
                <div class="row">
                    <div class="col s12">
                        <div class="KhungOverflow50">
                            <table class="responsive-table" id="DataGridView1Table">
                                <thead class="sticky-header">
                                    <tr onclick="DataGridView1Sort()">
                                        <th>Part Name</th>
                                        <th>Spec</th>
                                        <th>Location</th>
                                        <th>Current Stock</th>
                                        <th>Stock Warning</th>
                                        <th>Safety Stock</th>
                                        <th>Description</th>
                                        <th>Active</th>
                                        <th>Created Date</th>
                                        <th>Created By</th>
                                    </tr>
                                </thead>
                                <tbody id="DataGridView1">
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div id="Tab002" class="col s12">
                <div class="row">
                    <div class="col s12 m12 l12 card-panel green lighten-4">

                        <div class="col s12 m12 l3">
                            <div style="text-align: center; margin-top: 10px;">
                                <button id="btnScanIn" class="btn waves-effect waves-light cyan darken-1">SCAN</button>
                            </div>
                        </div>
                        <div class="col s12 m12 l3">
                            <div>
                                <label>From Date</label>
                                <input id="txt_ScanIn_FromDate" type="date" class="form-control">
                            </div>
                        </div>
                        <div class="col s12 m12 l3">
                            <div>
                                <label>To Date</label>
                                <input id="txt_ScanIn_ToDate" type="date" class="form-control">
                            </div>
                        </div>

                    </div>
                </div>
                <!-- Scan In History Table -->
                <div class="row">
                    <div class="col s12">
                        <div class="KhungOverflow60">
                            <table class="responsive-table" id="DataGridView2Table">
                                <thead class="sticky-header">
                                    <tr onclick="DataGridView2Sort()">
                                        <th>Code</th>
                                        <th>Part Name</th>
                                        <th>Quantity</th>
                                        <th>Safety Stock</th>
                                        <th>Current Stock</th>
                                        <th>Create Date</th>
                                        <th>Create User</th>
                                        <th>Reason For Use</th>
                                    </tr>
                                </thead>
                                <tbody id="DataGridView2">
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab 3: Scan Out History -->
            <div id="Tab003" class="col s12">
                <div class="row">
                    <div class="col s12 m12 l12 card-panel green lighten-4">
                        <div class="col s12 m12 l3">
                            <div style="text-align: center; margin-top: 10px;">
                                <button id="btnScanOut" class="btn waves-effect waves-light cyan darken-1">SCAN</button>
                            </div>
                        </div>
                        <div class="col s12 m12 l3">
                            <div>
                                <label>From Date</label>
                                <input id="txt_ScanOut_FromDate" type="date" class="form-control">
                            </div>
                        </div>

                        <div class="col s12 m12 l3">
                            <div>
                                <label>To Date</label>
                                <input id="txt_ScanOut_ToDate" type="date" class="form-control">
                            </div>
                        </div>


                    </div>
                </div>
                <!-- Scan Out History Table -->
                <div class="row">
                    <div class="col s12">
                        <div class="KhungOverflow60">
                            <table class="responsive-table" id="DataGridView3Table">
                                <thead class="sticky-header">
                                    <tr onclick="DataGridView3Sort()">
                                        <th>Code</th>
                                        <th>Part Name</th>
                                        <th>Quantity</th>
                                        <th>Safety Stock</th>
                                        <th>Current Stock</th>
                                        <th>Create Date</th>
                                        <th>Create User</th>
                                        <th>Reason For Use</th>
                                    </tr>
                                </thead>
                                <tbody id="DataGridView3">
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="scanInModal" class="modal">
    <div class="modal-content">
        <h4>Scan In Blade</h4>
        <div class="row">
            <div class="col s12 m6">
                <label for="modal_PartName">Part Name</label>
                <input id="modal_PartName" type="text" class="form-control">
            </div>
            <div class="col s12 m6">
                <label for="modal_Quantity">InPut Quantity</label>
                <input id="modal_Quantity" type="number" class="form-control">
            </div>
        </div>
        <div class="row">
            <div class="col s12 m6">
                <label for="modal_User">User</label>
                <input id="modal_User" type="text" class="form-control">
            </div>
            <div class="col s12 m6">
                <label for="modal_ReasonForUse">Reason For Use</label>
                <input id="modal_ReasonForUse" type="text" class="form-control">
            </div>
        </div>

    </div>
    <div class="modal-footer">
        <button id="btnScanInSave" class="btn waves-effect waves-light green">
            <i class="material-icons left">save</i>Save
        </button>
        <button class="btn waves-effect waves-light red modal-close">
            <i class="material-icons left">close</i>Cancel
        </button>
    </div>
</div>
<!-- Scan Out Modal -->
<div id="scanOutModal" class="modal">
    <div class="modal-content">
        <h4>Scan Out Blade</h4>
        <div class="row">
            <div class="col s12 m6">
                <label for="modal_PartName_Out">Part Name</label>
                <input id="modal_PartName_Out" type="text" class="form-control">
            </div>
            <div class="col s12 m6">
                <label for="modal_Quantity_Out">OutPut Quantity</label>
                <input id="modal_Quantity_Out" type="number" class="form-control">
            </div>
        </div>

        <div class="row">
            <div class="col s12 m6">
                <label for="modal_User_Out">User</label>
                <input id="modal_User_Out" type="text" class="form-control" value="">
            </div>
            <div class="col s12 m6">
                <label for="modal_ReasonForUse_Out">Reason For Use</label>
                <input id="modal_ReasonForUse_Out" type="text" class="form-control">
            </div>
        </div>

    </div>
    <div class="modal-footer">
        <button id="btnScanOutSave" class="btn waves-effect waves-light green">
            <i class="material-icons left">save</i>Save
        </button>
        <button class="btn waves-effect waves-light red modal-close">
            <i class="material-icons left">close</i>Cancel
        </button>
    </div>
</div>
<div id="ModalImportBlades" class="modal">
    <div class="modal-content">
        <div class="row" style="margin-bottom: 0;">
            <div class="col s8">
                <h4>Import Blade List</h4>
            </div>
            <div class="col s4 right-align">
                <button id="BtnSaveImport" class="btn waves-effect waves-light green darken-1">
                    <i class="material-icons left">save</i>Save
                </button>
                <button class="modal-close btn waves-effect waves-light red">
                    <i class="material-icons left">close</i>Cancel
                </button>
            </div>
        </div>
        <div class="file-field input-field">
            <div class="btn cyan">
                <span>File</span>
                <input id="FileImportBlades" type="file" accept=".xlsx,.xls">
            </div>
            <div class="file-path-wrapper">
                <input class="file-path validate" type="text" placeholder="Upload Excel file">
            </div>
        </div>
        <div class="progress" id="importProgress" style="display: none;">
            <div class="indeterminate"></div>
        </div>
        <div class="KhungOverflow">
            <table class="responsive-table striped">
                <thead>
                    <tr>
                        <th>Part Name</th>
                        <th>Specification</th>
                        <th>Location</th>
                        <th>Safety Stock</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody id="ImportPreviewTable"></tbody>
            </table>
        </div>
    </div>
</div>
<style>
    .warning-negative {
        background-color: #ff4444;
        color: white;
        font-weight: bold;
    }
</style>
<script src="~/Scripts/X02.js?v=@version"></script>

