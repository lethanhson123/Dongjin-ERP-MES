@inject CookieHelper CookieHelper
@{
	string version = GlobalHelper.InitializationDateTimeCode;
	string DomainSite = CookieHelper.GetCookie(GlobalHelper.DomainSite) ?? GlobalHelper.URLSite;
}
<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - DONGJIN</title>
	<meta name="description" content="DONGJIN GLOBAL COMPANY LIMITED | Manufacturing Execution System (MES) 2025" />
	<link rel="icon" type="image/x-icon" href="~/Image/logo.png">
	<meta property="og:site_name" content="dongjin-global.com" />
	<meta property="og:rich_attachment" content="true" />
	<meta property="og:type" content="article" />
	<meta property="og:url" itemprop="url" content="https://dongjin-global.com/" />
	<meta property="og:image" itemprop="thumbnailUrl" content="~/Image/logo01.png" />

	<link rel="stylesheet" type="text/css" href="~/app-assets/vendors/vendors.min.css">
	<link rel="stylesheet" type="text/css" href="~/app-assets/vendors/flag-icon/css/flag-icon.min.css">

	<link rel="stylesheet" type="text/css" href="~/app-assets/css/themes/horizontal-menu-template/materialize.css">
	<link rel="stylesheet" type="text/css" href="~/app-assets/css/themes/horizontal-menu-template/style.css">
	<link rel="stylesheet" type="text/css" href="~/app-assets/css/layouts/style-horizontal.css">
	<link rel="stylesheet" type="text/css" href="~/app-assets/css/custom/custom.css">
	<link rel="stylesheet" type="text/css" href="~/css/custom.css?v=@version">
	<script src="~/js/jquery-1.12.4.min.js"></script>

</head>
<body class="horizontal-layout page-header-light horizontal-menu 2-columns  " data-open="click"
	  data-menu="horizontal-menu" data-col="2-columns">
	<div id="BackGround" style="width:100%; height:100%; z-index:1000; background-color: #eeeeee; opacity: 0.5; position:absolute; top:0px; left:0px; display: none;">
		<div id="BackGroundDim" style="z-index:2000; position:absolute;">
			<div class="msgbox">
				<img src="~/Image/loading.gif" alt="Loading, please wait..." title="Loading, please wait..." width="200"
					 height="200" />
			</div>
		</div>
	</div>
	@RenderBody()
	<script src="~/app-assets/js/vendors.min.js" type="text/javascript"></script>
	<script src="~/app-assets/vendors/data-tables/js/jquery.dataTables.min.js" type="text/javascript"></script>
	<script src="~/app-assets/vendors/data-tables/extensions/responsive/js/dataTables.responsive.min.js"
			type="text/javascript"></script>
	<script src="~/app-assets/vendors/data-tables/js/dataTables.select.min.js" type="text/javascript"></script>
	<script src="~/app-assets/js/plugins.js" type="text/javascript"></script>
	<script src="~/app-assets/js/custom/custom-script.js" type="text/javascript"></script>
	<script src="~/app-assets/js/scripts/data-tables.js" type="text/javascript"></script>
	<script src="~/js/custom.js?v=@version"></script>
</body>
</html>
